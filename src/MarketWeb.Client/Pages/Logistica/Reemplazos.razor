@page "/logistica/reemplazos"
@implements IDisposable
@inject ReemplazosApi Api
@inject NavigationManager Nav
@inject PageStateService State
@inject UiService Ui

<PageTitle>Reemplazos</PageTitle>

<div class="market-page">
    @if (!string.IsNullOrWhiteSpace(Ref))
    {
        <button class="btn-volver" @onclick="Volver">
            <span class="ico"><i class="fa-solid fa-arrow-left"></i></span>
            <span>Volver</span>
        </button>
    }
    <PageHeader Modulo="Logística" Titulo="Reemplazos" Icono="fa-solid fa-retweet" CompartirQuery="@CompartirQuery" />

    @if (!string.IsNullOrEmpty(_filtroArt))
    {
        <div class="alert alert-info d-flex align-items-center py-2 mb-3">
            <i class="fa-solid fa-filter me-2"></i>
            <div class="flex-grow-1">Filtrando por artículo <strong>@_filtroArt</strong> (todos los reemplazos, incluso procesados).</div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => _filtroArt = "")">Quitar filtro</button>
        </div>
    }

    <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
        <div>
            <label class="form-label small text-muted mb-1">Local</label>
            <select class="form-select" style="min-width: 200px" @bind="_filtroLocal" @bind:after="Cargar">
                <option value="0">TODOS</option>
                @foreach (var l in _locales) { <option value="@l.Id">@l.Descripcion</option> }
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Mueble local</label>
            <select class="form-select" style="min-width: 170px" @bind="_filtroMueble">
                <option value="">TODOS</option>
                @foreach (var m in MueblesEnUso) { <option value="@m">@m</option> }
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Código artículo</label>
            <input class="form-control" style="width:150px" @bind="_filtroArt" @bind:event="oninput" placeholder="Ej: IH097" />
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="chkTodos" @bind="_verTodos" @bind:after="Cargar" />
            <label class="form-check-label small" for="chkTodos">Ver todos (incluye procesados)</label>
        </div>
        <button class="btn btn-outline-secondary" @onclick="Cargar"><i class="fa-solid fa-rotate me-1"></i> Actualizar</button>
        <button class="btn btn-primary" @onclick="AbrirAlta"><i class="fa-solid fa-plus me-1"></i> Nuevo reemplazo</button>
        <button class="btn btn-success" @onclick="MarcarProcesados" disabled="@(_items.Count == 0 || _procesando)" title="Marcar procesados y avisar a los locales">
            @if (_procesando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
            else { <i class="fa-solid fa-check me-1"></i> }
            Marcar procesado
        </button>
        <button class="btn btn-outline-dark ms-auto" @onclick='() => Nav.NavigateTo("/logistica/reemplazos-mueble")' title="Bloqueos de artículos por mueble">
            <i class="fa-solid fa-ban me-1"></i> Bloqueos por mueble
        </button>
    </div>

    @if (_mesasSinAsignar.Count > 0)
    {
        <div class="alert alert-danger" role="alert">
            <div class="d-flex align-items-center mb-1">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                <strong>Hay @_mesasSinAsignar.Count reemplazo(s) de mesa "PASAR A PERCHERO" sin asignar a un perchero.</strong>
            </div>
            <div class="small">Asignalos abriendo el reemplazo del perchero correspondiente. Igual podés procesar.</div>
            <ul class="small mb-0 mt-1">
                @foreach (var m in _mesasSinAsignar.Take(20))
                {
                    <li>@m.Local · <strong>@m.ArtCod</strong> @m.Descripcion @(string.IsNullOrWhiteSpace(m.Mueble) ? "" : $"({m.Mueble} {m.Modulo})")</li>
                }
                @if (_mesasSinAsignar.Count > 20)
                {
                    <li>… y @(_mesasSinAsignar.Count - 20) más.</li>
                }
            </ul>
        </div>
    }

    @if (_flash is not null)
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i><div class="flex-grow-1">@_flash</div>
            <button type="button" class="btn-close" @onclick="() => _flash = null"></button>
        </div>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i><div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Cargar">Reintentar</button>
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (ItemsFiltrados.Count == 0)
    {
        <div class="market-empty"><i class="fa-solid fa-retweet"></i><p>No hay reemplazos para el filtro.</p></div>
    }
    else
    {
        <div class="market-card table-responsive">
            <table class="market-table align-middle">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Local</th>
                        <th>Cód. Art.</th>
                        <th>Descripción</th>
                        <th>Posición local</th>
                        <th>Mueble local</th>
                        <th>Cód. Reemplazo</th>
                        <th>Descripción reemplazo</th>
                        <th>Ubic. depósito</th>
                        <th>Acción</th>
                        <th class="text-center" style="width: 96px">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in ItemsFiltrados)
                    {
                        <tr class="@(r.Procesado ? "fila-verde" : null)" @ondblclick="() => AbrirModif(r)">
                            <td class="small">@(r.Fecha?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td>@r.Ubicacion</td>
                            <td><ArticuloLink Codigo="@r.ArtCod" /></td>
                            <td>@r.DescripcionArt</td>
                            <td>@r.UbicacionLocal</td>
                            <td>@r.MobiliarioLocal</td>
                            <td><ArticuloLink Codigo="@r.ArtCodReemplazo" /></td>
                            <td>@r.DescripcionArtReemplazo</td>
                            <td>@r.UbicacionDeposito</td>
                            <td><span class="badge-perfil">@r.Accion</span></td>
                            <td class="text-center text-nowrap acciones">
                                <button class="btn btn-sm btn-outline-primary me-1" title="Modificar" @onclick="() => AbrirModif(r)">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" title="Eliminar" @onclick="() => Eliminar(r)">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">
            @ItemsFiltrados.Count reemplazo(s)@(string.IsNullOrEmpty(_filtroMueble) && string.IsNullOrWhiteSpace(_filtroArt) ? "" : $" de {_items.Count}").
        </p>
    }
</div>

@* ---------- Modal ABM ---------- *@
@if (_modalAbm)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_esAlta ? "Nuevo reemplazo" : "Modificar reemplazo")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarAbm"></button>
                </div>
                <div class="modal-body">
                    @if (_errorModal is not null)
                    {
                        <div class="alert alert-danger py-2">@_errorModal</div>
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Local</label>
                            <select class="form-select" @bind="_abmLocal" @bind:after="OnCambioLocal">
                                <option value="0">— Elegí el local —</option>
                                @foreach (var l in _locales) { <option value="@l.Id">@l.Descripcion</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Acción</label>
                            <select class="form-select" @bind="_abmAccion">
                                <option value="">— Elegí la acción —</option>
                                @foreach (var a in AccionesDisponibles) { <option value="@a">@a</option> }
                            </select>
                        </div>

                        <div class="col-12"><hr class="my-1" /><div class="fw-semibold small text-muted">ARTÍCULO A REEMPLAZAR</div></div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Código</label>
                            <input class="form-control" @bind="_abmArtCod" @bind:after="BuscarDescOrig" placeholder="Código del artículo" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small text-muted mb-1">Descripción</label>
                            <input class="form-control" value="@_abmDescArt" readonly />
                            @if (_validOrig is not null)
                            {
                                <span class="badge @(_validOrig.Ok ? "bg-success" : "bg-danger") mt-1">@_validOrig.Mensaje</span>
                            }
                            @if (!string.IsNullOrEmpty(_abmComboOrig)) { <span class="text-muted small ms-2">Combo: @_abmComboOrig</span> }
                        </div>

                        <div class="col-12">
                            <hr class="my-1" />
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="fw-semibold small text-muted">ARTÍCULO DE REEMPLAZO</div>
                                <button class="btn btn-sm btn-outline-info" @onclick="BuscarReemplazo">
                                    <i class="fa-solid fa-magnifying-glass me-1"></i> Buscar reemplazo
                                </button>
                            </div>
                        </div>

                        @if (_abmEsPerchero)
                        {
                            <div class="col-12">
                                <div class="alert alert-warning py-2 mb-2">
                                    <i class="fa-solid fa-arrows-turn-right me-1"></i>
                                    Este reemplazo está en <strong>PERCHERO</strong>. Asignale una <strong>mesa que pasa a perchero</strong> (1 a 1):
                                </div>
                                <select class="form-select" @bind="_abmMesaSel" @bind:after="OnElegirMesa">
                                    <option value="">— Elegí la mesa que viene a este perchero —</option>
                                    @foreach (var m in MesasElegibles)
                                    {
                                        <option value="@m.ArtCod">@m.ArtCod — @m.Descripcion@(string.IsNullOrWhiteSpace(m.Mueble) ? "" : $"  ·  {m.Mueble} {m.Modulo}")</option>
                                    }
                                </select>
                                @if (!MesasElegibles.Any())
                                {
                                    <div class="form-text text-danger">No hay mesas con acción "PASAR A PERCHERO" sin asignar en este local.</div>
                                }
                            </div>
                        }
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Código</label>
                            <input class="form-control" @bind="_abmArtReemp" @bind:after="BuscarDescReemp" placeholder="Código del reemplazo" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small text-muted mb-1">Descripción</label>
                            <input class="form-control" value="@_abmDescReemp" readonly />
                            @if (!string.IsNullOrEmpty(_abmComboReemp))
                            {
                                <span class="small ms-2 @(ComboDistinto ? "text-danger fw-semibold" : "text-muted")">
                                    Combo: @_abmComboReemp @(ComboDistinto ? "(distinto al original)" : "")
                                </span>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarAbm">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="Guardar" disabled="@_guardando">
                        @if (_guardando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@* ---------- Modal buscador de candidatos ---------- *@
@if (_modalCand)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="z-index: 1060">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Elegí el reemplazo @(_candEsPerchero ? "(en Perchero del local)" : "(propuestas del depósito)")</h5>
                    <button type="button" class="btn-close" @onclick="() => _modalCand = false"></button>
                </div>
                <div class="modal-body">
                    @if (_candCargando)
                    {
                        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Buscando...</p>
                    }
                    else if (_candidatos.Count == 0)
                    {
                        <p class="text-muted">No se encontraron reemplazos posibles.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="market-table align-middle">
                                <thead>
                                    <tr>
                                        <th>Cód. Art.</th><th>Descripción</th><th>Combo</th>
                                        @if (_candEsPerchero) { <th>Mueble</th><th>Módulo</th> }
                                        <th class="text-end">Stock</th>
                                        <th class="text-center" style="width:80px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var x in _candidatos)
                                    {
                                        @if (x.EsTitulo)
                                        {
                                            <tr class="fila-subtotal"><td colspan="@(_candEsPerchero ? 7 : 5)" class="fw-semibold">@x.Descripcion</td></tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td class="fw-semibold">@x.ArtCod</td>
                                                <td>@x.Descripcion</td>
                                                <td class="small text-muted">@x.Combo</td>
                                                @if (_candEsPerchero) { <td>@x.Mobiliario</td><td>@x.Modulo</td> }
                                                <td class="text-end @(x.Stock > 0 ? "" : "text-danger")">@x.Stock</td>
                                                <td class="text-center">
                                                    <button class="btn btn-sm btn-success" @onclick="() => ElegirCandidato(x)">Elegir</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _modalCand = false">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" style="z-index: 1055"></div>
}

<style>
    /* Botón Volver (mismo formato que Consulta de Artículo / Reposición) */
    .btn-volver {
        display: inline-flex; align-items: center; gap: 8px;
        background: #fff; border: 1px solid #e6e4dd; border-radius: 999px;
        padding: 6px 16px 6px 8px; margin-bottom: .5rem;
        color: #555; font-weight: 600; font-size: .9rem; cursor: pointer;
        box-shadow: 0 1px 2px rgba(16, 24, 40, .05);
        transition: background .12s ease, color .12s ease, transform .12s ease, box-shadow .12s ease;
    }
    .btn-volver .ico {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 50%;
        background: #fff3e0; color: #e8820c; transition: transform .12s ease;
    }
    .btn-volver:hover { background: #faf9f6; color: #1f2430; transform: translateX(-2px); box-shadow: 0 3px 10px rgba(16, 24, 40, .12); }
    .btn-volver:hover .ico { transform: translateX(-2px); }
</style>

@code {
    private List<LocalReemplazoDto> _locales = new();
    private int _filtroLocal;
    private string _filtroMueble = "";
    private string _filtroArt = "";   // viene por deep-link desde la Consulta de Reposición
    private bool _verTodos;
    private List<ReemplazoDto> _items = new();

    // Muebles (del local) presentes en lo cargado, para el combo de filtro.
    private List<string> MueblesEnUso => _items.Where(r => !string.IsNullOrWhiteSpace(r.MobiliarioLocal))
        .Select(r => r.MobiliarioLocal!.Trim()).Distinct().OrderBy(m => m).ToList();

    // Lo que se muestra: items filtrados por mueble y/o artículo (client-side sobre lo ya cargado).
    private List<ReemplazoDto> ItemsFiltrados
    {
        get
        {
            IEnumerable<ReemplazoDto> q = _items;
            if (!string.IsNullOrEmpty(_filtroMueble))
                q = q.Where(r => string.Equals(r.MobiliarioLocal?.Trim(), _filtroMueble, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(_filtroArt))
            {
                var f = _filtroArt.Trim();
                q = q.Where(r => (r.ArtCod ?? "").Contains(f, StringComparison.OrdinalIgnoreCase)
                              || (r.ArtCodReemplazo ?? "").Contains(f, StringComparison.OrdinalIgnoreCase));
            }
            return q.ToList();
        }
    }
    private bool _cargando = true;
    private bool _procesando;
    private string? _error;
    private string? _flash;

    // ABM
    private bool _modalAbm, _esAlta, _guardando;
    private int _editId, _abmLocal;
    private string _abmArtCod = "", _abmDescArt = "", _abmArtReemp = "", _abmDescReemp = "", _abmAccion = "", _abmComboOrig = "", _abmComboReemp = "";
    private ValidacionReemplazoDto? _validOrig;
    private string? _errorModal;

    // Candidatos
    private bool _modalCand, _candCargando, _candEsPerchero;
    private List<ReemplazoCandidatoDto> _candidatos = new();

    private static readonly string[] _accionesBase =
    {
        "DEFINIR REEMPLAZO", "ENVIAR A LOCAL", "ENVIAR A LOGÍSTICA", "PASAR A PERCHERO",
        "REEMPLAZADO POR MESA",
        "PASAR DE PERCHERO A PERCHERO DISCONTINUO", "UNIFICAR EN MEDIA MESA", "REEMPLAZO DE PANEL"
    };

    // Asignación mesa→perchero (lado del perchero): combo de mesas y bandera de si el reemplazo en edición es un perchero.
    private bool _abmEsPerchero;
    private string _abmMesaSel = "";
    private List<MesaPercheroDto> _mesas = new();         // mesas para el combo del modal (del local en edición)
    private List<MesaPercheroDto> _mesasSinAsignar = new(); // para el cartel rojo de la pantalla

    private bool ComboDistinto => !string.IsNullOrEmpty(_abmComboReemp) && !string.Equals(_abmComboOrig?.Trim(), _abmComboReemp?.Trim(), StringComparison.OrdinalIgnoreCase);

    // "ENVIAR A LOCAL" se vuelve "ENVIAR A PERALTA"/"ENVIAR A LURO" según el local (como en el .Net).
    private IEnumerable<string> AccionesDisponibles
    {
        get
        {
            var ln = LocalNombre(_abmLocal).ToUpperInvariant();
            var lista = _accionesBase.Select(a =>
                a == "ENVIAR A LOCAL" ? (ln == "LURO" ? "ENVIAR A PERALTA" : ln == "PERALTA" ? "ENVIAR A LURO" : "ENVIAR A LOCAL") : a).ToList();
            // Si la acción guardada no figura (caso edición), la agregamos para no perderla.
            if (!string.IsNullOrEmpty(_abmAccion) && !lista.Contains(_abmAccion)) lista.Insert(0, _abmAccion);
            return lista;
        }
    }

    private string LocalNombre(int id) => _locales.FirstOrDefault(l => l.Id == id)?.Descripcion ?? "";

    private const string StateKey = "reemplazos";
    private sealed class Snap { public List<LocalReemplazoDto> Locales = new(); public int FiltroLocal; public string FiltroMueble = ""; public bool VerTodos; public List<ReemplazoDto> Items = new(); public List<MesaPercheroDto> MesasSinAsignar = new(); }

    // Deep-link / Compartir: filtros en la URL (?local=&mueble=&todos=1).
    [Parameter, SupplyParameterFromQuery(Name = "local")] public int? LocalQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "mueble")] public string? MuebleQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "todos")] public bool? TodosQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "art")] public string? ArtQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "abrir")] public int? AbrirId { get; set; }   // abre ese reemplazo puntual
    [Parameter, SupplyParameterFromQuery(Name = "ref")] public string? Ref { get; set; }   // de dónde se llegó (Volver)

    private string CompartirQuery =>
        $"local={_filtroLocal}"
        + (string.IsNullOrEmpty(_filtroMueble) ? "" : $"&mueble={Uri.EscapeDataString(_filtroMueble)}")
        + (string.IsNullOrEmpty(_filtroArt) ? "" : $"&art={Uri.EscapeDataString(_filtroArt)}")
        + (_verTodos ? "&todos=true" : "");

    private void Volver() => Nav.NavigateTo(Ref!);

    protected override async Task OnInitializedAsync()
    {
        var hayQuery = LocalQ.HasValue || MuebleQ != null || TodosQ.HasValue || ArtQ != null || AbrirId.HasValue;

        // Si llega por link con filtros, mandan ellos (no el estado guardado).
        if (!hayQuery && State.TryGet<Snap>(StateKey, out var s, out _))
        {
            _locales = s.Locales; _filtroLocal = s.FiltroLocal; _filtroMueble = s.FiltroMueble; _verTodos = s.VerTodos; _items = s.Items; _mesasSinAsignar = s.MesasSinAsignar; _cargando = false;
            return;
        }
        try { _locales = await Api.LocalesAsync(); } catch { _locales = new(); }
        if (hayQuery)
        {
            if (LocalQ.HasValue) _filtroLocal = LocalQ.Value;
            if (MuebleQ != null) _filtroMueble = MuebleQ;
            if (TodosQ.HasValue) _verTodos = TodosQ.Value;
            // Llega desde la Consulta de Reposición por un artículo puntual: filtra por él y muestra todos
            // (también procesados) para ver qué acción se tomó.
            if (ArtQ != null) { _filtroArt = ArtQ.Trim(); _verTodos = true; }
        }
        await Cargar();

        // Deep-link a un reemplazo puntual: abre directo su ficha (lo que pidió el usuario para ver la Acción).
        if (AbrirId is int aid && aid > 0) await AbrirModif(new ReemplazoDto { Id = aid });
    }

    public void Dispose()
        => State.Save(StateKey, new Snap { Locales = _locales, FiltroLocal = _filtroLocal, FiltroMueble = _filtroMueble, VerTodos = _verTodos, Items = _items, MesasSinAsignar = _mesasSinAsignar }, 0);

    private async Task Cargar()
    {
        _cargando = true; _error = null;
        try { _items = await Api.ListarAsync(_filtroLocal, _verTodos); }
        catch (Exception ex) { _items = new(); _error = "No se pudieron cargar los reemplazos."; Console.Error.WriteLine(ex); }
        finally { _cargando = false; }
        // Mesas con acción PASAR A PERCHERO que todavía no asignó ningún perchero (para el cartel rojo).
        try { _mesasSinAsignar = (await Api.MesasParaPercheroAsync(_filtroLocal)).Where(m => !m.Asignado).ToList(); }
        catch { _mesasSinAsignar = new(); }
        // Si el mueble filtrado ya no existe en lo cargado (cambió el local), limpiamos el filtro.
        if (!string.IsNullOrEmpty(_filtroMueble) && !MueblesEnUso.Contains(_filtroMueble, StringComparer.OrdinalIgnoreCase))
            _filtroMueble = "";
    }

    private void AbrirAlta()
    {
        _esAlta = true; _editId = 0;
        _abmLocal = _filtroLocal; // si hay un local filtrado, lo pre-cargamos
        _abmArtCod = ""; _abmDescArt = ""; _abmArtReemp = ""; _abmDescReemp = ""; _abmAccion = "";
        _abmComboOrig = ""; _abmComboReemp = ""; _validOrig = null; _errorModal = null;
        _abmEsPerchero = false; _abmMesaSel = ""; _mesas = new();
        _modalAbm = true;
    }

    private async Task AbrirModif(ReemplazoDto r)
    {
        _errorModal = null;
        var ed = await Api.ObtenerAsync(r.Id);
        if (ed is null) { _error = "No se encontró el reemplazo."; return; }
        _esAlta = false; _editId = ed.Id; _abmLocal = ed.IdUbicacion;
        _abmArtCod = ed.ArtCod; _abmDescArt = ed.DescripcionArt;
        _abmArtReemp = ed.ArtCodReemplazo; _abmDescReemp = ed.DescripcionArtReemplazo;
        _abmAccion = ed.Accion;
        var a1 = await Api.ArticuloAsync(ed.ArtCod); _abmComboOrig = a1?.Combo ?? "";
        var a2 = string.IsNullOrEmpty(ed.ArtCodReemplazo) ? null : await Api.ArticuloAsync(ed.ArtCodReemplazo); _abmComboReemp = a2?.Combo ?? "";
        if (_abmLocal > 0 && !string.IsNullOrEmpty(ed.ArtCod)) _validOrig = await Api.ValidarAsync(_abmLocal, ed.ArtCod);

        // Si el reemplazo en edición está en un PERCHERO, ofrecemos asignarle una mesa que pasa a perchero (1 a 1).
        _abmEsPerchero = string.Equals(ed.MobiliarioLocal?.Trim(), "PERCHERO", StringComparison.OrdinalIgnoreCase);
        _abmMesaSel = _abmEsPerchero ? (ed.ArtCodReemplazo ?? "") : "";
        _mesas = _abmEsPerchero && _abmLocal > 0 ? await Api.MesasParaPercheroAsync(_abmLocal) : new();

        _modalAbm = true;
    }

    // Mesas que se pueden elegir para este perchero: las no asignadas + la que ya tiene asignada (para que se vea elegida).
    private IEnumerable<MesaPercheroDto> MesasElegibles =>
        _mesas.Where(m => !m.Asignado || string.Equals(m.ArtCod, _abmArtReemp, StringComparison.OrdinalIgnoreCase));

    private async Task OnElegirMesa()
    {
        var cod = (_abmMesaSel ?? "").Trim();
        if (cod.Length == 0)
        {
            // Desasignar: vuelve a quedar el perchero sin mesa (acción la elige el usuario).
            _abmArtReemp = ""; _abmDescReemp = ""; _abmComboReemp = "";
            return;
        }
        var m = _mesas.FirstOrDefault(x => string.Equals(x.ArtCod, cod, StringComparison.OrdinalIgnoreCase));
        _abmArtReemp = cod;
        _abmDescReemp = m?.Descripcion ?? "";
        _abmAccion = "REEMPLAZADO POR MESA";
        var a = await Api.ArticuloAsync(cod); _abmComboReemp = a?.Combo ?? "";
    }

    private void CerrarAbm() => _modalAbm = false;

    private async Task OnCambioLocal()
    {
        // Revalida el original con el nuevo local.
        if (_abmLocal > 0 && !string.IsNullOrWhiteSpace(_abmArtCod))
            _validOrig = await Api.ValidarAsync(_abmLocal, _abmArtCod.Trim());
        else _validOrig = null;
    }

    private async Task BuscarDescOrig()
    {
        _abmDescArt = ""; _abmComboOrig = ""; _validOrig = null; _errorModal = null;
        var c = (_abmArtCod ?? "").Trim();
        if (c.Length == 0) return;
        var a = await Api.ArticuloAsync(c);
        if (a is null || string.IsNullOrEmpty(a.Descripcion)) { _errorModal = "El código de artículo a reemplazar no es válido."; return; }
        _abmDescArt = a.Descripcion; _abmComboOrig = a.Combo;
        if (_abmLocal > 0) _validOrig = await Api.ValidarAsync(_abmLocal, c);
    }

    private async Task BuscarDescReemp()
    {
        _abmDescReemp = ""; _abmComboReemp = "";
        var c = (_abmArtReemp ?? "").Trim();
        if (c.Length == 0) return;
        var a = await Api.ArticuloAsync(c);
        if (a is null || string.IsNullOrEmpty(a.Descripcion)) { _errorModal = "El código de artículo de reemplazo no es válido."; return; }
        _abmDescReemp = a.Descripcion; _abmComboReemp = a.Combo;
    }

    private async Task BuscarReemplazo()
    {
        _errorModal = null;
        var c = (_abmArtCod ?? "").Trim();
        if (c.Length == 0) { _errorModal = "Primero ingresá el artículo a reemplazar."; return; }
        if (_abmLocal <= 0) { _errorModal = "Elegí el local."; return; }
        _candEsPerchero = _abmAccion == "PASAR A PERCHERO";
        _modalCand = true; _candCargando = true; _candidatos = new();
        try { _candidatos = _candEsPerchero ? await Api.CandidatosPercheroAsync(_abmLocal, c) : await Api.CandidatosAsync(_abmLocal, c); }
        catch (Exception ex) { _candidatos = new(); Console.Error.WriteLine(ex); }
        finally { _candCargando = false; }
    }

    private void ElegirCandidato(ReemplazoCandidatoDto x)
    {
        if (x.EsTitulo) return;
        _abmArtReemp = x.ArtCod; _abmDescReemp = x.Descripcion; _abmComboReemp = x.Combo;
        _modalCand = false;
    }

    private async Task Guardar()
    {
        _guardando = true; _errorModal = null;
        var (ok, err) = await Api.GuardarAsync(new ReemplazoSaveRequest
        {
            Id = _editId, IdUbicacion = _abmLocal,
            ArtCod = _abmArtCod, ArtCodReemplazo = _abmArtReemp, Accion = _abmAccion
        });
        _guardando = false;
        if (!ok) { _errorModal = err; return; }
        _modalAbm = false;
        await Cargar();
    }

    private async Task MarcarProcesados()
    {
        var pregunta = "¿Marcar TODOS los reemplazos visibles como procesados y notificar a los locales?";
        if (_mesasSinAsignar.Count > 0)
            pregunta += $"\n\nATENCIÓN: quedan {_mesasSinAsignar.Count} reemplazo(s) de mesa \"PASAR A PERCHERO\" sin asignar a un perchero.";
        var ok = await Ui.ConfirmAsync(pregunta, "Procesar reemplazos");
        if (!ok) return;
        _procesando = true; _error = null; _flash = null;
        try
        {
            var res = await Api.MarcarProcesadosAsync(_filtroLocal);
            if (res is null) { _error = "No se pudo procesar."; return; }
            var msg = $"Se procesaron {res.Procesados} reemplazo(s).";
            if (res.Saltados > 0) msg += $" Se saltaron {res.Saltados} sin reemplazo definido.";
            if (!res.SmtpConfigurado) msg += " (Mails NO enviados: el SMTP no está configurado en el servidor.)";
            else if (res.MailError is not null) msg += $" Atención: error al enviar mails: {res.MailError}";
            else msg += $" Mails enviados: {res.MailsEnviados}.";
            _flash = msg;
            await Cargar();
        }
        catch (Exception ex) { _error = "No se pudo procesar."; Console.Error.WriteLine(ex); }
        finally { _procesando = false; }
    }

    private async Task Eliminar(ReemplazoDto r)
    {
        var ok = await Ui.ConfirmAsync($"¿Eliminar el reemplazo de {r.ArtCod} en {r.Ubicacion}?", "Eliminar reemplazo", "Eliminar", "Cancelar", peligro: true);
        if (!ok) return;
        await Api.EliminarAsync(r.Id);
        await Cargar();
    }
}
