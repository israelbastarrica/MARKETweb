@page "/logistica/eventos"
@using MarketWeb.Shared.Reposicion
@implements IDisposable
@inject EventosApi Api
@inject ReposicionApi RepoApi
@inject PageStateService State
@inject UiService Ui
@inject NavigationManager Nav

<PageTitle>Eventos reposición</PageTitle>

<div class="market-page">
    @if (!string.IsNullOrWhiteSpace(Ref))
    {
        <button class="btn-volver" @onclick="Volver">
            <span class="ico"><i class="fa-solid fa-arrow-left"></i></span>
            <span>Volver</span>
        </button>
    }
    <PageHeader Modulo="Logística" Titulo="Eventos" Icono="fa-solid fa-triangle-exclamation" CompartirQuery="@CompartirQuery" />
    <p class="text-muted market-hint" style="margin-top:-.6rem">
        Sobrantes y faltantes que cargan los locales en piso. Doble clic / botón para ver el detalle, foto y marcarlo como procesado.
    </p>

    <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
        <div>
            <label class="form-label small text-muted mb-1">Local</label>
            <select class="form-select" @bind="_local">
                <option value="TODOS">TODOS</option>
                <option value="CENTRAL">CENTRAL</option>
                <option value="LURO">LURO</option>
                <option value="PERALTA">PERALTA</option>
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Desde</label>
            <input type="date" class="form-control" @bind="_desde" />
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Hasta</label>
            <input type="date" class="form-control" @bind="_hasta" />
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Código artículo</label>
            <input class="form-control" style="width:150px" @bind="_artFiltro" @bind:event="oninput" placeholder="Ej: IH097" />
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="chkTodos" @bind="_verTodos" @bind:after="Cargar" />
            <label class="form-check-label small" for="chkTodos">Ver todos (incluye procesados)</label>
        </div>
        <button class="btn btn-outline-secondary" @onclick="Cargar"><i class="fa-solid fa-magnifying-glass me-1"></i> Buscar</button>
    </div>

    @if (!_cargando && ItemsFiltrados.Count > 0)
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-3 py-2">
                <i class="fa-solid fa-clock me-1"></i> Sin procesar: <strong>@Pendientes</strong>
            </span>
            <span class="badge rounded-pill bg-success-subtle text-success-emphasis border border-success-subtle px-3 py-2">
                <i class="fa-solid fa-check me-1"></i> Procesados: <strong>@Procesados</strong>
            </span>
            <span class="badge rounded-pill bg-light text-muted border px-3 py-2">
                Total: <strong>@ItemsFiltrados.Count</strong>
            </span>
            @if (!_verTodos)
            {
                <span class="small text-muted align-self-center">(marcá "Ver todos" para incluir los ya procesados)</span>
            }
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (ItemsFiltrados.Count == 0)
    {
        <div class="market-empty"><i class="fa-solid fa-triangle-exclamation"></i><p>No hay eventos para el filtro.</p></div>
    }
    else
    {
        <div class="market-card table-responsive">
            <table class="market-table align-middle ev-tabla">
                <thead>
                    <tr>
                        <th>Fecha</th><th>Local</th><th>ARTCOD</th><th>Descripción</th><th>Remito</th>
                        <th class="text-center">Tipo</th><th class="text-end">Cant. Packs</th>
                        <th class="text-center">Foto</th><th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in ItemsFiltrados)
                    {
                        <tr class="@(ev.Estado != "PENDIENTE" ? "ev-cerrado" : "")" @ondblclick="() => AbrirDetalle(ev.Id)">
                            <td class="small">@ev.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@ev.Local</td>
                            <td>
                                @if (!string.IsNullOrEmpty(ev.ArtCod))
                                {
                                    @if (ev.Local == "LURO" || ev.Local == "PERALTA")
                                    {
                                        <span class="art-cod-link">
                                            <span class="badge-perfil">@ev.ArtCod</span>
                                            <a class="art-cod-ir" href="@($"/logistica/consulta-reposicion?local={ev.Local}&art={Uri.EscapeDataString(ev.ArtCod)}&ref={Uri.EscapeDataString("/logistica/eventos")}")"
                                               title="Ver consulta de reposición (remitos, venta, packs)">
                                                <i class="fa-solid fa-up-right-from-square"></i>
                                            </a>
                                        </span>
                                    }
                                    else
                                    {
                                        <ArticuloLink Codigo="@ev.ArtCod" Local="@ev.Local" />
                                    }
                                }
                            </td>
                            <td>@ev.Descripcion</td>
                            <td class="small">@ev.RemitoDisplay</td>
                            <td class="text-center fw-bold @TipoClase(ev.TipoDiferencia)">@ev.TipoDiferencia</td>
                            <td class="text-end">@ev.CantidadPacks</td>
                            <td class="text-center">@(ev.TieneFoto ? "✓" : "")</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => AbrirDetalle(ev.Id)" title="Ver detalle">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">
            @ItemsFiltrados.Count evento@(ItemsFiltrados.Count == 1 ? "" : "s") ·
            @ItemsFiltrados.Count(e => e.TipoDiferencia == "SOBRANTE") sobrante(s) ·
            @ItemsFiltrados.Count(e => e.TipoDiferencia == "FALTANTE") faltante(s)
        </p>
    }
</div>

@if (_modal && _det is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title @TipoClase(_det.TipoDiferencia)">
                        EVENTO: @_det.TipoDiferencia — @_det.Local (@_det.TipoCodigo)
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => _modal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="small text-muted mb-3">
                        <span>Fecha: @_det.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                        @if (!string.IsNullOrEmpty(_det.CodigoEscaneado)) { <span> · Código: @_det.CodigoEscaneado</span> }
                        @if (!string.IsNullOrEmpty(_det.RemitoDisplay)) { <span> · Remito: @_det.RemitoDisplay</span> }
                        @if (!string.IsNullOrEmpty(_det.DescripcionArt)) { <span> · @_det.DescripcionArt</span> }
                        @if (!string.IsNullOrEmpty(_det.CantidadPacks)) { <span> · Cant. packs: @_det.CantidadPacks</span> }
                        @if (!string.IsNullOrEmpty(_det.Usuario)) { <span> · Usuario: @_det.Usuario</span> }
                    </div>

                    <div class="row g-3">
                        @if (_det.TieneFoto)
                        {
                            <div class="col-md-5">
                                <a href="@($"api/eventos/{_det.Id}/foto")" target="_blank" rel="noopener" title="Ver grande">
                                    <img src="@($"api/eventos/{_det.Id}/foto")" class="ev-foto" alt="Foto del evento" />
                                </a>
                            </div>
                        }
                        <div class="@(_det.TieneFoto ? "col-md-7" : "col-12")">
                            @if (_det.Items.Count == 0)
                            {
                                <p class="text-muted small">@(_det.TipoCodigo == "REMITO" ? "(remito sin items o no encontrado en Dragon)" : "(sin remito asociado)")</p>
                            }
                            else
                            {
                                <table class="market-table align-middle">
                                    <thead><tr><th>Cód.Art</th><th>Descripción</th><th>Color</th><th>Talle</th><th class="text-end">Cant.</th></tr></thead>
                                    <tbody>
                                        @foreach (var it in _det.Items)
                                        {
                                            <tr>
                                                <td>@it.ArtCod</td><td>@it.Descripcion</td><td>@it.Color</td>
                                                <td class="text-center">@it.Talle</td><td class="text-end fw-bold">@it.Cantidad</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>

                    @if (!_det.Eliminado && !string.IsNullOrEmpty(_det.ArtCod) && (_det.Local == "LURO" || _det.Local == "PERALTA"))
                    {
                        <hr />
                        <div class="d-flex flex-wrap align-items-end gap-2">
                            <div>
                                <label class="form-label small text-muted mb-1">Acción del encargado</label>
                                <select class="form-select form-select-sm" style="min-width:200px" @bind="_accion" @bind:after="GuardarAccion">
                                    <option value="">— sin decidir —</option>
                                    <option value="RESETEAR VENTA">RESETEAR VENTA</option>
                                    <option value="REPONER Y RESETEAR VENTA">REPONER Y RESETEAR VENTA</option>
                                    <option value="ENVIAR REFUERZO">ENVIAR REFUERZO</option>
                                    <option value="ESPERAR VENTA">ESPERAR VENTA</option>
                                </select>
                            </div>
                            @if (EsAccionReset)
                            {
                                <div class="flex-grow-1" style="min-width:160px">
                                    <label class="form-label small text-muted mb-1">Comentario (opcional)</label>
                                    <input class="form-control form-control-sm" @bind="_accionComentario" maxlength="400" placeholder="Motivo..." />
                                </div>
                                <button class="btn btn-danger btn-sm" @onclick="AplicarReset" disabled="@_accionando">
                                    @if (_accionando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                                    Aplicar reset
                                </button>
                            }
                        </div>
                        @if (EsAccionReset)
                        {
                            <div class="form-text">Re-ancla el artículo al último remito y pone el pendiente en cero. FALTANTE suma packs, SOBRANTE los resta.</div>
                        }
                    }

                    @* Motivo normalizado (causa del desvío). Disponible para cualquier evento no eliminado. *@
                    @if (!_det.Eliminado)
                    {
                        <hr />
                        <div class="d-flex flex-wrap align-items-end gap-2">
                            <div style="min-width:260px">
                                <label class="form-label small text-muted mb-1">Motivo (causa del desvío)</label>
                                <div class="input-group input-group-sm">
                                    <select class="form-select" @bind="_idMotivoSel" @bind:after="GuardarMotivo">
                                        <option value="0">— sin motivo —</option>
                                        @foreach (var m in _motivos) { <option value="@m.Id">@m.Nombre</option> }
                                    </select>
                                    <button class="btn btn-outline-success" type="button" title="Agregar un motivo nuevo al catálogo"
                                            @onclick="() => _agregandoMotivo = !_agregandoMotivo">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                            @if (_agregandoMotivo)
                            {
                                <div class="input-group input-group-sm" style="max-width:340px">
                                    <input class="form-control" placeholder="Nuevo motivo..." @bind="_nuevoMotivo" @onkeyup="OnMotivoKey" maxlength="200" />
                                    <button class="btn btn-success" type="button" @onclick="AgregarMotivo" disabled="@_guardandoMotivo">Agregar</button>
                                </div>
                            }
                        </div>
                        <div class="form-text">Normalizá la causa (ej. "Refuerzo excesivo", "Pack mal cargado", "Venta no reflejada"). El <b>+</b> da de alta un motivo nuevo al catálogo.</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (_det.Eliminado)
                    {
                        <span class="text-muted">Evento eliminado.</span>
                    }
                    else
                    {
                        <button class="btn btn-outline-danger me-auto" @onclick="Eliminar" disabled="@_accionando">
                            <i class="fa-solid fa-trash me-1"></i> Eliminar (carga errada)
                        </button>
                        @if (_det.Procesado)
                        {
                            <span class="badge text-bg-secondary">YA PROCESADO</span>
                        }
                        else
                        {
                            <button class="btn btn-success" @onclick="MarcarProcesado" disabled="@_accionando">
                                @if (_accionando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                                else { <i class="fa-solid fa-check me-1"></i> }
                                Marcar procesado
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private string _local = "TODOS";
    private DateTime _desde = DateTime.Today.AddDays(-30);
    private DateTime _hasta = DateTime.Today;
    private bool _verTodos;

    private List<EventoDto> _items = new();
    private string _artFiltro = "";
    private List<EventoDto> ItemsFiltrados => string.IsNullOrWhiteSpace(_artFiltro)
        ? _items
        : _items.Where(e => (e.ArtCod ?? "").Contains(_artFiltro.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();
    private bool _cargando = true;

    private bool _modal, _accionando;
    private EventoDetalleDto? _det;
    private string _accion = "", _accionComentario = "";

    // Motivos normalizados (catálogo + alta inline).
    private List<MotivoEventoDto> _motivos = new();
    private int _idMotivoSel;
    private string _nuevoMotivo = "";
    private bool _agregandoMotivo, _guardandoMotivo;

    private const string StateKey = "eventos";
    private sealed class Snap { public string Local = "TODOS"; public DateTime Desde; public DateTime Hasta; public bool VerTodos; public List<EventoDto> Items = new(); }

    // Deep-link / Compartir: filtros en la URL (?local=&desde=&hasta=&todos=1).
    [Parameter, SupplyParameterFromQuery(Name = "local")] public string? LocalQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "desde")] public string? DesdeQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "hasta")] public string? HastaQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "todos")] public bool? TodosQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "abrir")] public int? AbrirId { get; set; }   // abre ese evento al entrar (desde la consulta)
    [Parameter, SupplyParameterFromQuery(Name = "ref")] public string? Ref { get; set; }      // de dónde se llegó (Volver)

    private string CompartirQuery =>
        $"local={Uri.EscapeDataString(_local)}&desde={_desde:yyyy-MM-dd}&hasta={_hasta:yyyy-MM-dd}" + (_verTodos ? "&todos=true" : "");

    private void Volver() => Nav.NavigateTo(Ref!);

    protected override async Task OnInitializedAsync()
    {
        var hayQuery = LocalQ != null || DesdeQ != null || HastaQ != null || TodosQ.HasValue || AbrirId.HasValue;

        if (!hayQuery && State.TryGet<Snap>(StateKey, out var s, out _))
        {
            // _verTodos NO se restaura a propósito: arranca destildado en cada entrada (antes quedaba tildado solo).
            _local = s.Local; _desde = s.Desde; _hasta = s.Hasta; _items = s.Items; _cargando = false;
            return;
        }
        if (hayQuery)
        {
            if (LocalQ != null) _local = LocalQ;
            if (DateTime.TryParse(DesdeQ, out var d)) _desde = d;
            if (DateTime.TryParse(HastaQ, out var h)) _hasta = h;
            if (TodosQ.HasValue) _verTodos = TodosQ.Value;
            // Si vino con ?abrir=, mostramos todos para que el evento aparezca en la grilla aunque ya esté procesado.
            if (AbrirId.HasValue) _verTodos = true;
        }
        await Cargar();

        // Deep-link a un evento puntual (desde la Consulta de Reposición): abre su ficha para procesarlo.
        if (AbrirId is int aid && aid > 0) await AbrirDetalle(aid);
    }

    public void Dispose()
        => State.Save(StateKey, new Snap { Local = _local, Desde = _desde, Hasta = _hasta, VerTodos = _verTodos, Items = _items }, 0);

    private static string TipoClase(string tipo) => tipo switch
    {
        "SOBRANTE" => "ev-sobrante",
        "FALTANTE" => "ev-faltante",
        _ => ""
    };

    private async Task Cargar()
    {
        _cargando = true;
        try { _items = await Api.ListarAsync(_local, _desde, _hasta, _verTodos); }
        catch { _items = new(); }
        finally { _cargando = false; }
    }

    private async Task AbrirDetalle(int id)
    {
        if (_motivos.Count == 0) { try { _motivos = await Api.ListarMotivosAsync(); } catch { } }
        _det = await Api.DetalleAsync(id);
        if (_det is not null)
        {
            _accion = _det.Accion;
            _accionComentario = "";
            _idMotivoSel = _det.IDMotivoEvento ?? 0;
            _nuevoMotivo = ""; _agregandoMotivo = false;
            _modal = true;
        }
    }

    private async Task GuardarMotivo()
    {
        if (_det is null) return;
        await Api.GuardarMotivoAsync(_det.Id, _idMotivoSel);
        _det.IDMotivoEvento = _idMotivoSel == 0 ? null : _idMotivoSel;
    }

    private async Task OnMotivoKey(KeyboardEventArgs e) { if (e.Key == "Enter") await AgregarMotivo(); }

    private async Task AgregarMotivo()
    {
        var n = (_nuevoMotivo ?? "").Trim();
        if (n.Length == 0 || _det is null) return;
        _guardandoMotivo = true;
        try
        {
            var m = await Api.CrearMotivoAsync(n);
            if (m is not null)
            {
                if (!_motivos.Any(x => x.Id == m.Id)) _motivos.Add(m);
                _motivos = _motivos.OrderBy(x => x.Nombre).ToList();
                _idMotivoSel = m.Id;
                await GuardarMotivo();
                _nuevoMotivo = ""; _agregandoMotivo = false;
            }
        }
        finally { _guardandoMotivo = false; }
    }

    // Contadores del reporte (sobre lo cargado): con "Ver todos" reflejan el total real del filtro.
    private int Pendientes => ItemsFiltrados.Count(e => e.Estado == "PENDIENTE");
    private int Procesados => ItemsFiltrados.Count(e => e.Estado != "PENDIENTE");

    // Solo RESETEAR VENTA dispara el reset manual al instante. En REPONER Y RESETEAR VENTA
    // el reset lo resuelve el SP cuando entra el remito de reposición (reset por remito posterior).
    private bool EsAccionReset => _accion == "RESETEAR VENTA";

    private async Task GuardarAccion()
    {
        if (_det is null) return;
        await Api.GuardarAccionAsync(_det.Id, _accion);
        _det.Accion = _accion;
    }

    private async Task AplicarReset()
    {
        if (_det is null) return;
        if (!await Ui.ConfirmAsync(
            $"¿Resetear {_det.ArtCod} en {_det.Local} desde el último remito? Re-ancla la cuenta de reposición.", "Resetear artículo")) return;
        _accionando = true;
        var res = await RepoApi.ResetearDesdeEventoAsync(_det.Id, _accionComentario);
        _accionando = false;
        if (res.Ok) Ui.Exito(res.Mensaje); else Ui.Error(res.Mensaje);
        if (res.Ok) await Cargar();
    }

    private async Task MarcarProcesado()
    {
        if (_det is null) return;
        _accionando = true;
        var ok = await Api.MarcarProcesadoAsync(_det.Id);
        _accionando = false;
        if (ok)
        {
            _det.Procesado = true;
            // Si se llegó desde la Consulta de Reposición (?ref=), volvemos a ESA consulta para seguir
            // procesando los eventos del MISMO artículo (no al reporte, que mezcla artículos y hace perder el hilo).
            if (!string.IsNullOrWhiteSpace(Ref)) { Nav.NavigateTo(Ref); return; }
        }
        await Cargar();
    }

    private async Task Eliminar()
    {
        if (_det is null) return;
        if (!await Ui.ConfirmAsync("¿Eliminar este evento? Es para cargas erradas, no para procesarlo.", "Eliminar evento", "Eliminar", "Cancelar", peligro: true)) return;
        _accionando = true;
        if (await Api.EliminarAsync(_det.Id)) { _modal = false; await Cargar(); }
        _accionando = false;
    }
}
