@page "/logistica/remito-nuevo"
@using System.Text.RegularExpressions
@implements IDisposable
@inject DragonApi Api
@inject IJSRuntime JS
@inject UiService Ui
@inject LayoutState Layout

<PageTitle>Remito nuevo</PageTitle>

<div class="market-page rn">
    <PageHeader Modulo="Logística" Titulo="Remito nuevo" Icono="fa-solid fa-file-circle-plus" />

    @if (_dragonOff)
    {
        <div class="alert alert-warning"><i class="fa-solid fa-triangle-exclamation me-2"></i>La API Dragonfish no está configurada en el servidor — no se puede dar de alta el remito.</div>
    }

    @if (string.IsNullOrEmpty(_licencia))
    {
        <div class="alert alert-warning"><i class="fa-solid fa-triangle-exclamation me-2"></i>Esta tablet no tiene impresora asignada — configurá "Esta PC".</div>
    }

    <div class="market-card p-3 mb-3">
        <div class="row g-3 align-items-end">
            <div class="col-6 col-md-3">
                <label class="form-label">Local destino</label>
                <select class="form-select form-select-lg" value="@_local" @onchange="OnLocalChange">
                    <option value="LURO">LURO</option>
                    <option value="PERALTA">PERALTA</option>
                </select>
            </div>
            <div class="col-6 col-md-5">
                <label class="form-label">Motivo</label>
                <select class="form-select form-select-lg" @bind="_motivo">
                    @foreach (var m in _motivos)
                    {
                        <option value="@m.Cod">@m.Cod - @m.Des</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-4 d-flex align-items-center">
                <button class="btn btn-outline-dark btn-lg ms-md-auto" @onclick="ToggleAncho" title="Pantalla completa horizontal (tablet)">
                    <i class="fa-solid @(_ancho ? "fa-compress" : "fa-expand") me-1"></i>@(_ancho ? "Salir" : "Pantalla ancha")
                </button>
            </div>
        </div>

        @* Modo de carga: manual / escanear / por N° de remito de local *@
        <div class="d-flex gap-2 flex-wrap mt-3">
            <button class="btn btn-lg @(_modo == "manual" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetModo("manual")'>
                <i class="fa-solid fa-pen me-1"></i>Manual
            </button>
            <button class="btn btn-lg @(_modo == "escanear" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetModo("escanear")'>
                <i class="fa-solid fa-camera me-1"></i>Escanear bolsa
            </button>
            <button class="btn btn-lg @(_modo == "remito" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetModo("remito")'>
                <i class="fa-solid fa-file-import me-1"></i>Por N° de remito
            </button>
        </div>
    </div>

    @* ---- MODO ESCANEAR: bolsa del depósito (código de barras/QR) ---- *@
    @if (_modo == "escanear")
    {
        <div class="market-card p-3 mb-3">
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <button class="btn btn-dark btn-lg" @onclick="AbrirScanner">
                    <i class="fa-solid fa-camera me-2"></i>Escanear bolsa
                </button>
                <span class="text-muted">o</span>
                <div class="input-group input-group-lg rn-bolsa-manual">
                    <span class="input-group-text">N° bolsa</span>
                    <input class="form-control" @bind="_nroBolsaManual" @onkeyup="OnKeyBolsa" placeholder="tipealo a mano" />
                    <button class="btn btn-outline-secondary" @onclick="BuscarBolsaManual"><i class="fa-solid fa-magnifying-glass"></i></button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_scanError))
            {
                <div class="alert alert-warning mt-2 mb-0 py-2 small">@_scanError</div>
            }
        </div>
    }

    @* ---- MODO REMITO: levantar el detalle de un remito existente del local ---- *@
    @if (_modo == "remito")
    {
        <div class="market-card p-3 mb-3">
            <div class="row g-2 align-items-end">
                <div class="col-6 col-md-3">
                    <label class="form-label small text-muted mb-1">Local del remito</label>
                    <select class="form-select form-select-lg" @bind="_remLocal">
                        <option value="LURO">LURO</option>
                        <option value="PERALTA">PERALTA</option>
                    </select>
                </div>
                <div class="col-3 col-md-2">
                    <label class="form-label small text-muted mb-1">Punto</label>
                    <input type="number" min="1" class="form-control form-control-lg" @bind="_remPunto" onfocus="this.select()" />
                </div>
                <div class="col-9 col-md-4">
                    <label class="form-label small text-muted mb-1">Número</label>
                    <input type="number" min="1" class="form-control form-control-lg" @bind="_remNumero" @onkeyup="OnKeyRemito" onfocus="this.select()" />
                </div>
                <div class="col-12 col-md-3 d-grid">
                    <button class="btn btn-primary btn-lg" @onclick="LevantarRemito" disabled="@_buscandoRemito">
                        @if (_buscandoRemito) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                        <i class="fa-solid fa-download me-1"></i>Levantar
                    </button>
                </div>
            </div>
            <div class="text-muted small mt-2">Trae los renglones de un remito que ya hizo el local (se lee en vivo de su Dragon).</div>
        </div>
    }

    @* ---- MODO MANUAL: carga de renglones artículo por artículo ---- *@
    <div class="market-card rn-carga p-3 mb-3" style="@(_modo == "manual" ? "" : "display:none")">
        @* Código (angosto, ~10 chars) con autocomplete + descripción justo debajo *@
        <div class="row g-2">
            <div class="col-12 position-relative">
                <label class="form-label small text-muted mb-1">Código (ARTCOD)</label>
                <div class="d-flex align-items-center gap-2">
                    <input class="form-control form-control-lg rn-cod @(_artNoEncontrado ? "is-warning" : null)"
                           value="@_artcod"
                           @oninput="OnArtCodInput"
                           @onblur="OnArtCodBlur"
                           @ref="_inpArt"
                           autocomplete="off"
                           placeholder="Ej: IH097.427" />
                    @if (!string.IsNullOrEmpty(_artcod) || !string.IsNullOrEmpty(_color))
                    {
                        <button class="btn btn-outline-secondary btn-lg" @onclick="LimpiarCarga" title="Limpiar y arrancar de cero">
                            <i class="fa-solid fa-eraser me-1"></i>Limpiar
                        </button>
                    }
                </div>
                @if (_sugerencias.Count > 0)
                {
                    <ul class="rn-sugerencias">
                        @foreach (var s in _sugerencias)
                        {
                            <li @onmousedown:preventDefault @onmousedown="() => SeleccionarArticulo(s)">
                                <span class="fw-bold me-2">@s.ArtCod</span>
                                <small class="text-muted">@s.ArtDes</small>
                            </li>
                        }
                    </ul>
                }
                <div class="rn-desc">
                    @if (_buscandoArt)
                    {
                        <span class="text-muted"><i class="fa-solid fa-spinner fa-spin me-1"></i>Buscando…</span>
                    }
                    else if (!string.IsNullOrEmpty(_artDes))
                    {
                        <span class="text-success fw-semibold"><i class="fa-solid fa-check me-1"></i>@_artDes</span>
                    }
                    else if (_artNoEncontrado)
                    {
                        <span class="text-danger"><i class="fa-solid fa-triangle-exclamation me-1"></i>No existe en el catálogo (ART). Revisá el código.</span>
                    }
                    else
                    {
                        <span>&nbsp;</span>
                    }
                </div>
            </div>
        </div>

        @* Una vez validado el artículo: elegir color → grilla de talles. *@
        @if (!string.IsNullOrEmpty(_artDes))
        {
            @if (_variantes.Count > 0)
            {
                @if (_colores.Count > 0)
                {
                    <div class="row g-2 align-items-end mt-1">
                        <div class="col-12 col-md-4">
                            <label class="form-label small text-muted mb-1">Color</label>
                            <select class="form-select form-select-lg" value="@_color" @onchange="OnColorChange">
                                <option value="">— Elegí un color —</option>
                                @foreach (var c in _colores) { <option value="@c">@c</option> }
                            </select>
                        </div>
                    </div>
                }

                @if (_tallesDeColor.Count > 0)
                {
                    <div class="rn-grilla mt-3">
                        @foreach (var t in _tallesDeColor)
                        {
                            <div class="rn-talle">
                                <div class="rn-talle-lbl">@(string.IsNullOrEmpty(t) ? "—" : t)</div>
                                <input type="number" min="0" inputmode="numeric"
                                       class="form-control form-control-lg text-center"
                                       value="@_cantPorTalle[t]"
                                       @onchange="(e) => SetCant(t, e)" onfocus="this.select()" />
                            </div>
                        }
                    </div>
                    <div class="d-grid d-md-flex justify-content-md-end mt-3">
                        <button class="btn btn-primary btn-lg" @onclick="AgregarColor">
                            <i class="fa-solid fa-plus me-1"></i>
                            Agregar@(string.IsNullOrEmpty(_color) ? "" : $" {_color}") (@TotalGrilla u.)
                        </button>
                    </div>
                }
            }
            else
            {
                @* Artículo sin variantes en COMB: una sola línea con cantidad. *@
                <div class="row g-2 align-items-end mt-1">
                    <div class="col-6 col-md-2">
                        <label class="form-label small text-muted mb-1">Cantidad</label>
                        <input type="number" min="1" class="form-control form-control-lg" @bind="_cantSimple" onfocus="this.select()" />
                    </div>
                    <div class="col-6 col-md-3 d-grid">
                        <button class="btn btn-primary btn-lg" @onclick="AgregarSimple"><i class="fa-solid fa-plus me-1"></i>Agregar</button>
                    </div>
                </div>
            }
        }
    </div>

    @if (_items.Count > 0)
    {
        <div class="market-card table-responsive mb-3">
            <table class="market-table align-middle rn-table">
                <thead>
                    <tr><th>Código</th><th>Descripción</th><th>Color</th><th>Talle</th><th class="text-end">Cant.</th><th style="width:60px"></th></tr>
                </thead>
                <tbody>
                    @foreach (var it in _items)
                    {
                        <tr>
                            <td class="fw-semibold">@it.Articulo</td>
                            <td class="text-muted small">@it.Descripcion</td>
                            <td>@it.Color</td>
                            <td>@it.Talle</td>
                            <td class="text-end">@it.Cantidad</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Quitar(it)"><i class="fa-solid fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-semibold"><td colspan="4" class="text-end">Total</td><td class="text-end">@_items.Sum(i => i.Cantidad)</td><td></td></tr>
                </tfoot>
            </table>
        </div>

        <div class="d-grid d-md-flex justify-content-md-end gap-2">
            <button class="btn btn-outline-danger btn-lg" @onclick="VaciarTodo" disabled="@_enviando">
                <i class="fa-solid fa-trash-can me-1"></i> Vaciar remito
            </button>
            <button class="btn btn-success btn-lg" @onclick="DarDeAlta" disabled="@(_enviando || _dragonOff || string.IsNullOrEmpty(_licencia))">
                @if (_enviando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                <i class="fa-solid fa-paper-plane me-1"></i> Dar de alta el remito (@_items.Count renglón(es))
            </button>
        </div>
    }
    else
    {
        <div class="market-empty"><i class="fa-solid fa-boxes-stacked"></i><p>Escaneá una <strong>bolsa</strong>, o buscá un artículo y cargá cantidades por <strong>talle</strong>. Después dale <strong>Dar de alta</strong>.</p></div>
    }

    @if (_diag is not null)
    {
        <div class="market-card p-3 mb-3 rn-diag">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong class="text-danger"><i class="fa-solid fa-bug me-1"></i>Dragon rechazó el remito (HTTP @_diag.HttpStatus)</strong>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _diag = null">Cerrar</button>
            </div>
            <label class="form-label small text-muted mb-1">Respuesta de Dragon</label>
            <textarea class="form-control mb-2 rn-mono" rows="6" readonly>@_diag.Respuesta</textarea>
            <label class="form-label small text-muted mb-1">JSON que enviamos</label>
            <textarea class="form-control rn-mono" rows="8" readonly>@_diag.JsonEnviado</textarea>
        </div>
    }
</div>

@if (_escaneando)
{
    <div class="rn-scan-overlay">
        <div class="rn-scan-box">
            <div class="rn-scan-hint"><i class="fa-solid fa-barcode me-2"></i>Apuntá al código de barras de la bolsa…</div>
            <video id="rn-video" class="rn-scan-video" muted autoplay playsinline></video>
            <button class="btn btn-light btn-lg mt-3" @onclick="CerrarScanner"><i class="fa-solid fa-xmark me-2"></i>Cancelar</button>
        </div>
    </div>
}

<style>
    .rn-table td, .rn-table th { font-size: 1.05rem; }

    /* La card de carga NO debe recortar el desplegable de sugerencias
       (el .market-card global tiene overflow:hidden por el redondeo). */
    .rn-carga { overflow: visible; }

    /* El código son ~10 caracteres: campo angosto, no a todo el ancho. Siempre mayúsculas. */
    .rn-cod { max-width: 240px; text-transform: uppercase; }

    .rn-desc {
        min-height: 1.5rem;
        margin-top: .4rem;
        font-size: .95rem;
        line-height: 1.3;
    }

    /* Grilla de talles: un casillero por talle con su cantidad. */
    .rn-grilla {
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
    }

    .rn-talle { width: 88px; }

    .rn-talle-lbl {
        font-size: .9rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: .25rem;
        color: var(--mk-text-strong);
    }

    .rn-sugerencias {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 200;
        list-style: none;
        margin: 2px 0 0;
        padding: 4px 0;
        background: var(--mk-surface);
        border: 1px solid var(--mk-border);
        border-radius: 8px;
        box-shadow: 0 4px 16px rgba(0,0,0,.15);
        max-height: 220px;
        overflow-y: auto;
    }

    .rn-sugerencias li {
        padding: 8px 14px;
        cursor: pointer;
        display: flex;
        align-items: baseline;
        gap: 6px;
        font-size: .95rem;
        transition: background .1s;
    }

    .rn-sugerencias li:hover {
        background: var(--mk-surface-2);
    }

    .form-control.is-warning {
        border-color: #f59e0b;
    }

    .rn-bolsa-manual { max-width: 520px; flex: 1 1 380px; }

    .rn-diag { border: 1px solid var(--mk-danger, #dc3545); }
    .rn-mono { font-family: ui-monospace, Consolas, monospace; font-size: .8rem; white-space: pre; }

    /* Overlay de escaneo: pantalla completa con el video de la cámara. */
    .rn-scan-overlay {
        position: fixed;
        inset: 0;
        z-index: 1080;
        background: rgba(0, 0, 0, .9);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .rn-scan-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 92vw;
    }

    .rn-scan-hint { color: #fff; font-size: 1.05rem; margin-bottom: .6rem; }

    .rn-scan-video {
        width: min(720px, 94vw);
        max-height: 70vh;
        background: #000;
        border-radius: 12px;
        overflow: hidden;
        display: block;
        object-fit: cover;
    }
</style>

@code {
    private string _local = "LURO";
    private string _licencia = "";
    private string _etiquetaPc = "esta tablet";

    // Motivo del remito (combo); arranca en 02 REPOSICION. El elegido se manda en el alta.
    private string _motivo = "02";
    private List<MotivoDto> _motivos = new();

    // Modo de carga: "" (sin elegir) / "manual" / "escanear" / "remito".
    private string _modo = "";
    private void SetModo(string m) { _modo = m; _scanError = ""; if (m == "remito") _remLocal = _local; }

    // Modo "remito": levantar el detalle de un remito existente del local.
    private string _remLocal = "LURO";
    private int _remPunto = 1, _remNumero;
    private bool _buscandoRemito;

    // Impresoras = licencias destino (van a InformacionAdicional; el agente rutea por ahí cuando ve SALTAFW del server).
    private static readonly (string Licencia, string Nombre)[] Impresoras =
    {
        ("809131", "Impresora 1"),
        ("809129", "Impresora 2"),
    };

    // --- Renglones del remito ---
    private sealed class RenglonItem
    {
        public string Articulo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public string Color { get; set; } = "";
        public string Talle { get; set; } = "";
        public int Cantidad { get; set; }
    }
    private readonly List<RenglonItem> _items = new();

    // --- Estado de carga ---
    private string _artcod = "";
    private bool _enviando, _dragonOff;
    private ElementReference _inpArt;

    // --- Autocomplete (última repo) ---
    private List<UltimaRepoItemDto> _repoItems = new();
    private List<UltimaRepoItemDto> _sugerencias = new();

    // --- Artículo validado + variantes ---
    private string _artDes = "";
    private bool _buscandoArt, _artNoEncontrado;
    private List<ComboVarianteDto> _variantes = new();   // todas las variantes color+talle (COMB)
    private List<string> _colores = new();               // colores distintos
    private string _color = "";                          // color elegido
    private List<string> _tallesDeColor = new();         // talles del color elegido
    private Dictionary<string, int> _cantPorTalle = new();// talle -> cantidad cargada
    private int _cantSimple = 1;                         // para artículos sin variantes

    private int TotalGrilla => _cantPorTalle.Values.Sum();

    protected override async Task OnInitializedAsync()
    {
        _dragonOff = !await Api.ConfiguradoRemitoAsync();
        _repoItems = await Api.UltimaRepoAsync(_local);

        _motivos = await Api.MotivosAsync();
        // Garantizamos que el default 02 siempre esté disponible aunque falle la lectura.
        if (!_motivos.Any(m => m.Cod == "02"))
            _motivos.Insert(0, new MotivoDto { Cod = "02", Des = "REPOSICION" });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var pc = "";
            try { pc = await JS.InvokeAsync<string>("localStorage.getItem", DevicePcState.KeyNombre) ?? ""; } catch { }
            pc = pc.Trim();
            if (!string.IsNullOrEmpty(pc)) _etiquetaPc = pc;
            _licencia = LicenciasTablet.Licencia(pc) ?? "";
            StateHasChanged();
        }

        // El <video> recién existe tras renderizar el overlay: arrancamos acá la cámara.
        if (_scanPendiente && _escaneando)
        {
            _scanPendiente = false;
            await IniciarScanner();
        }
    }

    private async Task OnLocalChange(ChangeEventArgs e)
    {
        _local = e.Value?.ToString() ?? "LURO";
        _repoItems = await Api.UltimaRepoAsync(_local);
        _sugerencias.Clear();
    }

    // ---------------- Escanear bolsa ----------------

    private bool _escaneando, _scanPendiente;
    private string _scanError = "", _nroBolsaManual = "";
    private IJSObjectReference? _scanModule;
    private DotNetObjectReference<RemitoNuevo>? _selfRef;

    private void AbrirScanner()
    {
        _scanError = "";
        _escaneando = true;
        _scanPendiente = true;   // OnAfterRenderAsync arranca la cámara cuando el <video> ya existe
    }

    private async Task IniciarScanner()
    {
        try
        {
            _scanModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/rnscan.js");
            _selfRef ??= DotNetObjectReference.Create(this);
            await _scanModule.InvokeAsync<bool>("start", "rn-video", _selfRef);
        }
        catch (Exception ex)
        {
            _escaneando = false;
            _scanError = "No se pudo abrir la cámara: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task CerrarScanner()
    {
        _escaneando = false;
        if (_scanModule is not null) { try { await _scanModule.InvokeVoidAsync("stop"); } catch { } }
    }

    [JSInvokable]
    public async Task OnScanResult(string codigo)
    {
        _escaneando = false;
        await ProcesarBolsa(codigo);
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnScanError(string motivo)
    {
        _escaneando = false;
        _scanError = motivo switch
        {
            "no-soportado" => "Esta tablet no permite leer con la cámara. Tipeá el N° de bolsa a mano.",
            "permiso" => "Falta permiso de cámara. Habilitalo en el navegador, o tipeá el N° de bolsa.",
            _ => $"No se pudo usar la cámara ({motivo}). Tipeá el N° de bolsa a mano."
        };
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnKeyBolsa(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await BuscarBolsaManual();
    }

    private async Task BuscarBolsaManual()
    {
        var nro = (_nroBolsaManual ?? "").Trim();
        if (string.IsNullOrEmpty(nro)) return;
        await ProcesarBolsa(nro);
        _nroBolsaManual = "";
    }

    // Trae el detalle de la bolsa y suma todos sus renglones al remito.
    private async Task ProcesarBolsa(string nroBolsa)
    {
        _scanError = "";
        var bolsa = await Api.BuscarBolsaAsync(nroBolsa);
        if (bolsa is null) { Ui.Error($"No se encontró la bolsa {nroBolsa}."); return; }
        if (bolsa.Renglones.Count == 0) { Ui.Error($"La bolsa {nroBolsa} no tiene renglones."); return; }

        var u = 0;
        foreach (var r in bolsa.Renglones)
        {
            MergeItem(r.ArtCod, r.ArtDes, r.Color, r.Talle, r.Cantidad);
            u += r.Cantidad;
        }
        var etiqueta = bolsa.Eliminada ? $"{nroBolsa} (archivada)" : nroBolsa;
        Ui.Exito($"Bolsa {etiqueta}: +{bolsa.Renglones.Count} renglón(es), {u} u.");
    }

    // ---------------- Modo remito: levantar detalle de un remito existente del local ----------------

    private async Task OnKeyRemito(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LevantarRemito();
    }

    private async Task LevantarRemito()
    {
        if (_remPunto <= 0 || _remNumero <= 0) { Ui.Error("Poné punto y número del remito."); return; }
        _buscandoRemito = true;
        try
        {
            var renglones = await Api.BuscarRemitoLocalAsync(_remLocal, _remPunto, _remNumero);
            if (renglones.Count == 0)
            {
                Ui.Error($"No se encontró el remito {_remPunto}-{_remNumero} en {_remLocal} (o no tiene renglones).");
                return;
            }
            var u = 0;
            foreach (var r in renglones)
            {
                MergeItem(r.ArtCod, r.ArtDes, r.Color, r.Talle, r.Cantidad);
                u += r.Cantidad;
            }
            Ui.Exito($"Remito {_remPunto}-{_remNumero} de {_remLocal}: +{renglones.Count} renglón(es), {u} u.");
        }
        catch (Exception ex) { Ui.Error("Error al levantar el remito: " + ex.Message); }
        finally { _buscandoRemito = false; }
    }

    public void Dispose()
    {
        _selfRef?.Dispose();
        if (_scanModule is not null) { _ = _scanModule.DisposeAsync(); }
        if (_pantallaModule is not null) { _ = _pantallaModule.DisposeAsync(); }
    }

    // ---------------- Autocomplete ----------------

    private void OnArtCodInput(ChangeEventArgs e)
    {
        _artcod = (e.Value?.ToString() ?? "").ToUpperInvariant();
        _artDes = "";
        _artNoEncontrado = false;
        ResetVariantes();

        var q = _artcod.Trim();
        if (q.Length < 2) { _sugerencias.Clear(); return; }
        _sugerencias = _repoItems
            .Where(i => i.ArtCod.Contains(q, StringComparison.OrdinalIgnoreCase)
                     || i.ArtDes.Contains(q, StringComparison.OrdinalIgnoreCase))
            .Take(10)
            .ToList();
    }

    private async Task SeleccionarArticulo(UltimaRepoItemDto item)
    {
        _artcod = item.ArtCod;
        _sugerencias.Clear();
        await ValidarArticuloAsync(item.ArtCod);
    }

    private async Task OnArtCodBlur()
    {
        _sugerencias.Clear();
        var cod = (_artcod ?? "").Trim();
        if (cod.Length < 3) return;
        if (!string.IsNullOrEmpty(_artDes)) return; // ya validado
        await ValidarArticuloAsync(cod);
    }

    private async Task ValidarArticuloAsync(string cod)
    {
        _buscandoArt = true;
        _artDes = "";
        _artNoEncontrado = false;
        ResetVariantes();
        StateHasChanged();

        var lookup = await Api.BuscarArticuloAsync(cod.ToUpperInvariant());
        _buscandoArt = false;
        if (lookup is not null)
        {
            _artDes = lookup.Des;
            SetVariantes(lookup.Variantes);
        }
        else
        {
            _artNoEncontrado = true;
        }
    }

    // ---------------- Variantes / grilla ----------------

    private void SetVariantes(List<ComboVarianteDto> variantes)
    {
        _variantes = variantes ?? new();
        _colores = _variantes.Select(v => v.Color)
                             .Where(c => !string.IsNullOrWhiteSpace(c))
                             .Distinct()
                             .ToList();
        _color = "";
        _tallesDeColor = new();
        _cantPorTalle = new();

        // Artículo con talles pero sin color con nombre: mostramos la grilla directo (color vacío).
        if (_colores.Count == 0 && _variantes.Count > 0)
            CargarTallesDe("");
    }

    private void ResetVariantes()
    {
        _variantes = new();
        _colores = new();
        _color = "";
        _tallesDeColor = new();
        _cantPorTalle = new();
    }

    private void OnColorChange(ChangeEventArgs e)
    {
        _color = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(_color)) { _tallesDeColor = new(); _cantPorTalle = new(); return; }
        CargarTallesDe(_color);
    }

    private void CargarTallesDe(string color)
    {
        _tallesDeColor = _variantes
            .Where(v => v.Color == color)
            .Select(v => v.Talle)
            .Distinct()
            .OrderBy(EscalaIndex)                              // primero la escala de letras (S<M<L<XL...)
            .ThenBy(ClaveNatural, StringComparer.Ordinal)      // después orden natural (8<10<38<40, T2<T10)
            .ToList();
        _cantPorTalle = _tallesDeColor.ToDictionary(t => t, _ => 0);
    }

    // --- Orden de talles (propio, sin depender de Dragon) ---

    // Escala de letras conocida: si el talle es uno de estos, manda este orden.
    private static readonly string[] EscalaLetras =
    {
        "XXXS", "XXS", "XS", "S", "M", "L", "XL", "XXL", "XXXL", "4XL", "5XL", "6XL", "7XL"
    };

    // Talles de letra → su posición en la escala. Lo que no es escala va al final (MaxValue),
    // y ahí ordena la clave natural (numéricos por valor, alfanuméricos parejos).
    private static int EscalaIndex(string talle)
    {
        var i = Array.IndexOf(EscalaLetras, (talle ?? "").Trim().ToUpperInvariant());
        return i >= 0 ? i : int.MaxValue;
    }

    // Clave de orden natural: rellena cada bloque de dígitos a 10 para que el orden
    // de texto sea numérico de verdad ("8" < "10" < "38" < "40", "T2" < "T10").
    private static string ClaveNatural(string talle) =>
        Regex.Replace((talle ?? "").Trim().ToUpperInvariant(), @"\d+", m => m.Value.PadLeft(10, '0'));

    private void SetCant(string talle, ChangeEventArgs e)
    {
        int.TryParse(e.Value?.ToString(), out var q);
        if (q < 0) q = 0;
        _cantPorTalle[talle] = q;
    }

    // ---------------- Agregar ----------------

    private void AgregarColor()
    {
        var conCant = _tallesDeColor.Where(t => _cantPorTalle.TryGetValue(t, out var q) && q > 0).ToList();
        if (conCant.Count == 0) { Ui.Error("Cargá cantidad en al menos un talle."); return; }

        foreach (var t in conCant)
            MergeItem(_artcod, _artDes, _color, t, _cantPorTalle[t]);

        var color = string.IsNullOrEmpty(_color) ? "(sin color)" : _color;
        var u = conCant.Sum(t => _cantPorTalle[t]);
        // Reset para el próximo color, manteniendo el artículo.
        _color = "";
        _tallesDeColor = new();
        _cantPorTalle = new();
        Ui.Toast($"Agregado {color}: {conCant.Count} talle(s), {u} u.");
    }

    private async Task AgregarSimple()
    {
        var cod = (_artcod ?? "").Trim().ToUpperInvariant();
        if (string.IsNullOrEmpty(cod) || string.IsNullOrEmpty(_artDes)) { Ui.Error("Validá primero el artículo."); return; }
        if (_cantSimple <= 0) { Ui.Error("La cantidad tiene que ser mayor a 0."); return; }

        MergeItem(cod, _artDes, "", "", _cantSimple);
        _cantSimple = 1;
        LimpiarArticulo();
        try { await _inpArt.FocusAsync(); } catch { }
    }

    // Suma si ya existe (mismo artículo+color+talle), si no agrega renglón nuevo.
    private void MergeItem(string art, string des, string color, string talle, int cant)
    {
        var ex = _items.FirstOrDefault(i => i.Articulo == art && i.Color == color && i.Talle == talle);
        if (ex is not null) ex.Cantidad += cant;
        else _items.Add(new RenglonItem { Articulo = art, Descripcion = des, Color = color, Talle = talle, Cantidad = cant });
    }

    private void LimpiarArticulo()
    {
        _artcod = "";
        _artDes = "";
        _artNoEncontrado = false;
        _sugerencias.Clear();
        ResetVariantes();
    }

    // Botón "Limpiar": descarta la carga en curso (artículo + color + grilla) y vuelve a foco.
    private async Task LimpiarCarga()
    {
        LimpiarArticulo();
        _scanError = "";
        try { await _inpArt.FocusAsync(); } catch { }
    }

    // ---------------- Pantalla ancha (tablets) ----------------

    private bool _ancho;
    private bool _menuPrevio;
    private IJSObjectReference? _pantallaModule;

    private async Task ToggleAncho()
    {
        try
        {
            _pantallaModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/pantalla.js");
            if (_ancho)
            {
                _ancho = await _pantallaModule.InvokeAsync<bool>("salir");
                Layout.SetMenuColapsado(_menuPrevio);          // restaurar el menú como estaba
            }
            else
            {
                _menuPrevio = Layout.MenuColapsado;             // recordar para restaurar al salir
                _ancho = await _pantallaModule.InvokeAsync<bool>("entrar");
                if (_ancho) Layout.SetMenuColapsado(true);      // colapsar el menú = máximo ancho
            }
        }
        catch { /* sin soporte: queda como estaba */ }
    }

    private void Quitar(RenglonItem it) => _items.Remove(it);

    // Vacía TODA la tabla de renglones cargados (con confirmación, descarta todo).
    private async Task VaciarTodo()
    {
        if (_items.Count == 0) return;
        if (!await Ui.ConfirmAsync($"¿Vaciar el remito? Se quitan los {_items.Count} renglón(es) cargados.",
                "Vaciar remito", "Vaciar", "Cancelar", true))
            return;
        _items.Clear();
        LimpiarArticulo();
        _diag = null;
    }

    private DragonRemitoResultDto? _diag;

    private async Task DarDeAlta()
    {
        if (_items.Count == 0) return;
        var nombreImp = Impresoras.FirstOrDefault(i => i.Licencia == _licencia).Nombre ?? _licencia;
        if (!await Ui.ConfirmAsync(
            $"Dar de alta el remito a {_local} con {_items.Count} renglón(es), para imprimir en {nombreImp}?", "Dar de alta remito"))
            return;

        _diag = null;
        _enviando = true;
        try
        {
            var res = await Api.CrearRemitoAsync(new DragonRemitoRequest
            {
                Local = _local,
                Motivo = string.IsNullOrWhiteSpace(_motivo) ? "02" : _motivo,
                InformacionAdicional = _licencia,
                Items = _items.Select(i => new DragonRemitoItemDto
                {
                    Articulo = i.Articulo,
                    Color = i.Color,
                    Talle = i.Talle,
                    Cantidad = i.Cantidad
                }).ToList()
            });
            if (res.Ok)
            {
                Ui.Exito($"Remito creado en Dragon (N° {res.Numero?.ToString() ?? "?"}). Va a imprimir en {nombreImp}.");
                _items.Clear();
                LimpiarArticulo();
            }
            else
            {
                _diag = res;   // mostramos JSON enviado + respuesta de Dragon para diagnosticar
                Ui.Error("Dragon rechazó el remito. Mirá el detalle abajo.");
            }
        }
        catch (Exception ex) { Ui.Error("Error: " + ex.Message); }
        finally { _enviando = false; }
    }
}
