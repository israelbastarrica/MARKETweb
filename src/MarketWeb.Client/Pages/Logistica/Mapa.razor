@page "/logistica/mapa"
@implements IAsyncDisposable
@inject MapaApi Api
@inject IJSRuntime JS

<PageTitle>Mapa</PageTitle>

<div class="market-page">
    <PageHeader Modulo="Logística" Titulo="Mapa" Icono="fa-solid fa-cube" />

    <div class="market-card p-3 mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Código</label>
                <input class="form-control form-control-sm" placeholder="ARTCOD..." @bind="_f.CodArt" @onkeyup="OnKey" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small text-muted mb-1">Descripción</label>
                <input class="form-control form-control-sm" @bind="_f.Descripcion" @onkeyup="OnKey" />
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small text-muted mb-1">Tipo</label>
                <select class="form-select form-select-sm" @bind="_f.Tipo">
                    <option value="">Todos</option>
                    @foreach (var t in _combos.Tipos) { <option value="@t">@t</option> }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Combo</label>
                <select class="form-select form-select-sm" @bind="_f.Combo">
                    <option value="">Todos</option>
                    @foreach (var c in _combos.Combos) { <option value="@c">@c</option> }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Familia</label>
                <select class="form-select form-select-sm" @bind="_f.Familia">
                    <option value="">Todas</option>
                    @foreach (var fa in _combos.Familias) { <option value="@fa">@fa</option> }
                </select>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label small text-muted mb-1">Categoría</label>
                <select class="form-select form-select-sm" @bind="_f.Categoria">
                    <option value="">Todas</option>
                    @foreach (var c in _combos.Categorias) { <option value="@c">@c</option> }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Temporada</label>
                <select class="form-select form-select-sm" @bind="_f.Temporada">
                    <option value="">Todas</option>
                    @foreach (var t in _combos.Temporadas) { <option value="@t">@t</option> }
                </select>
            </div>
            <div class="col-3 col-md-1">
                <label class="form-label small text-muted mb-1">Año</label>
                <select class="form-select form-select-sm" @bind="_f.Anio">
                    <option value="0">Todos</option>
                    @foreach (var a in _combos.Anios) { <option value="@a">@a</option> }
                </select>
            </div>
            <div class="col-9 col-md-3">
                <label class="form-label small text-muted mb-1">Proveedor</label>
                <select class="form-select form-select-sm" @bind="_f.CodProveedor">
                    <option value="">Todos</option>
                    @foreach (var p in _combos.Proveedores) { <option value="@p.Codigo">@p.Nombre</option> }
                </select>
            </div>

            <div class="col-12 col-md-8 d-flex align-items-center gap-3 flex-wrap">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="chkSoloLoc" @bind="_f.SoloEnLocales" />
                    <label class="form-check-label small" for="chkSoloLoc">Solo en locales</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="chkSinFoto" @bind="_f.LocalesSinFotoGoogle" />
                    <label class="form-check-label small" for="chkSinFoto">Locales sin foto</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="chkFecha" @bind="_f.FiltraFechaAlta" />
                    <label class="form-check-label small" for="chkFecha">Por fecha de alta</label>
                </div>
                @if (_f.FiltraFechaAlta)
                {
                    <input type="date" class="form-control form-control-sm" style="width:auto" @bind="_f.FechaDesde" />
                    <span class="text-muted small">a</span>
                    <input type="date" class="form-control form-control-sm" style="width:auto" @bind="_f.FechaHasta" />
                }
            </div>
            <div class="col-12 col-md-4 d-flex align-items-end justify-content-end gap-2">
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn @(_vista == "REG" ? "btn-primary" : "btn-outline-primary")" @onclick='() => CambiarVista("REG")'>
                        <i class="fa-solid fa-table me-1"></i> Registros
                    </button>
                    <button type="button" class="btn @(_vista == "MAP" ? "btn-primary" : "btn-outline-primary")" @onclick='() => CambiarVista("MAP")'>
                        <i class="fa-solid fa-cube me-1"></i> Mapa
                    </button>
                </div>
                <button class="btn btn-primary btn-sm" @onclick="Procesar" disabled="@_cargando">
                    @if (_cargando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                    <i class="fa-solid fa-magnifying-glass me-1"></i> Procesar
                </button>
            </div>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Procesar">Reintentar</button>
        </div>
    }

    @* ---- Vista REGISTROS ---- *@
    <div class="@(_vista == "REG" ? "" : "d-none")">
        @if (_cargando)
        {
            <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Procesando...</p>
        }
        else if (!_procesado)
        {
            <div class="market-empty"><i class="fa-solid fa-filter"></i><p>Elegí los filtros y tocá <strong>Procesar</strong>.</p></div>
        }
        else if (_resultado.Filas.Count == 0)
        {
            <div class="market-empty"><i class="fa-solid fa-table-cells"></i><p>Sin resultados para los filtros.</p></div>
        }
        else
        {
            <p class="text-muted small mb-2">@_resultado.Filas.Count artículo(s) · @_resultado.Modulos.Count módulo(s) con ubicación.</p>
            <div class="market-card table-responsive">
                <table class="market-table align-middle">
                    <thead>
                        <tr>
                            <th>Código</th><th>Descripción</th><th>Proveedor</th><th>Combo</th>
                            <th>Familia</th><th>Tipo</th><th>Temp.</th><th class="text-center">Año</th><th>Categoría</th>
                            <th class="text-end">Central</th><th class="text-end">CCentral</th>
                            <th class="text-end">Luro</th><th class="text-end">Peralta</th><th class="text-center">Ubic.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _resultado.Filas)
                        {
                            <tr>
                                <td class="text-nowrap"><ArticuloLink Codigo="@r.Codigo" /></td>
                                <td>@r.Descripcion</td>
                                <td class="small">@r.Proveedor</td>
                                <td class="small">@r.Combo</td>
                                <td class="small">@r.Familia</td>
                                <td class="small">@r.Tipo</td>
                                <td class="small">@r.Temporada</td>
                                <td class="text-center">@(r.Anio == 0 ? "" : r.Anio.ToString())</td>
                                <td class="small">@r.Categoria</td>
                                <td class="text-end">@r.StockCentral.ToString("N0")</td>
                                <td class="text-end">@r.StockCCentral.ToString("N0")</td>
                                <td class="text-end">@r.StockLuro.ToString("N0")</td>
                                <td class="text-end">@r.StockPeralta.ToString("N0")</td>
                                <td class="text-center">@r.CantUbis</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* ---- Vista MAPA (3D) — el iframe queda siempre montado para no recargar el modelo de 22MB ---- *@
    <div class="@(_vista == "MAP" ? "" : "d-none")">
        <div class="market-card mapa3d-card">
            <iframe @ref="_iframe" src="/mapa3d/index.html" class="mapa3d-frame" title="Mapa 3D del depósito"></iframe>
        </div>
    </div>
</div>

<style>
    .mapa3d-card { padding: 0; overflow: hidden; }
    .mapa3d-frame { width: 100%; height: calc(100vh - 230px); min-height: 460px; border: 0; display: block; }
</style>

@code {
    private readonly MapaReporteFiltro _f = new();
    private MapaCombosDto _combos = new();
    private MapaReporteResultado _resultado = new();
    private bool _cargando, _procesado;
    private string? _error;
    private string _vista = "REG";   // REG | MAP
    private ElementReference _iframe;
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        try { _combos = await Api.CombosAsync(); }
        catch (Exception ex) { _error = "No se pudieron cargar los filtros."; Console.Error.WriteLine(ex); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/mapa.js");
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Procesar();
    }

    private async Task Procesar()
    {
        _cargando = true; _error = null;
        try
        {
            _resultado = await Api.ReporteAsync(_f);
            _procesado = true;
            await ResaltarEnMapaAsync();
        }
        catch (Exception ex) { _error = "No se pudo procesar el reporte."; Console.Error.WriteLine(ex); }
        finally { _cargando = false; }
    }

    private async Task CambiarVista(string v)
    {
        _vista = v;
        if (v == "MAP") await ResaltarEnMapaAsync();
    }

    // Manda al visor 3D la lista de módulos del resultado para que los resalte.
    private async Task ResaltarEnMapaAsync()
    {
        if (!_procesado || _module is null) return;
        try { await _module.InvokeVoidAsync("resaltar", _iframe, _resultado.Modulos); }
        catch (Exception ex) { Console.Error.WriteLine(ex); }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
        }
    }
}
