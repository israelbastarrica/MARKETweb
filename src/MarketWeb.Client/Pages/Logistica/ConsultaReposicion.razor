@page "/logistica/consulta-reposicion"
@using MarketWeb.Shared.Reposicion
@inject ReposicionApi Api
@inject EventosApi EventosApi
@inject PageStateService State
@inject IJSRuntime JS

<PageTitle>Consulta Reposición</PageTitle>

<div class="market-page cr">
    <PageHeader Modulo="Logística" Titulo="Consulta Artículo" Icono="fa-solid fa-magnifying-glass-chart" />

    <fieldset class="cr-box">
        <legend>Datos</legend>
        <div class="cr-datos">
            <label>LOCAL:</label>
            <select class="form-select form-select-sm" style="width:160px" @bind="_local">
                <option value="LURO">LURO</option>
                <option value="PERALTA">PERALTA</option>
            </select>
            <label>COD. ART:</label>
            <input class="form-control form-control-sm" style="width:140px" @bind="_artCod" @onkeyup="OnKey" />
            <span class="cr-desc">@(_d?.ArtDes)</span>
            @if (_d is not null && !string.IsNullOrEmpty(_d.ArtCod))
            {
                <ArticuloLink Codigo="@_d.ArtCod" Badge="false" />
            }
            <div class="cr-datos-btns">
                <button class="btn btn-primary btn-sm" @onclick="Buscar" disabled="@_cargando">
                    @if (_cargando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                    PROCESAR
                </button>
            </div>
        </div>
    </fieldset>

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Procesando...</p>
    }
    else if (_d is not null)
    {
        var r = _d.Resumen;

        <fieldset class="cr-box">
            <legend>Ubicaciones</legend>
            <div class="table-responsive cr-ubi-wrap">
                <table class="market-table align-middle cr-ubi">
                    <thead><tr><th>Ubicación</th><th>Mobiliario</th><th>Módulo</th><th class="text-center">Pasillo</th><th class="text-center">Fila</th><th class="text-center">Posición</th><th class="text-center">Fecha/Hora</th></tr></thead>
                    <tbody>
                        @foreach (var u in _d.Ubicaciones)
                        {
                            <tr class="@(u.EsDeposito ? "cr-dep" : "cr-loc")">
                                <td>@u.Ubicacion</td><td>@u.Mobiliario</td><td>@u.Modulo</td>
                                <td class="text-center">@u.Pasillo</td><td class="text-center">@u.Fila</td><td class="text-center">@u.Posicion</td>
                                <td class="text-center small">@(u.FechaHora?.ToString("dd/MM/yy HH:mm"))</td>
                            </tr>
                        }
                        @if (_d.EnPalet)
                        {
                            <tr class="cr-palet"><td colspan="7">EN PALET (depósito)</td></tr>
                        }
                        else if (!_d.Ubicaciones.Any(u => u.EsDeposito))
                        {
                            <tr class="cr-nodep"><td colspan="7">⚠ NO ESTÁ EN DEPÓSITO</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </fieldset>

        <fieldset class="cr-box">
            <legend>Remitos y Ventas</legend>

            <div class="cr-cards">
                <div class="cr-card cr-card-pack">
                    <div class="cr-card-t">UNIDADES POR PACK</div>
                    <div class="cr-card-n @(PackRoto(r) ? "cr-rojo" : "")">@r.CantPack</div>
                    <div class="cr-card-s @(PackRoto(r) ? "cr-rojo" : "")">@PackSub(r)</div>
                </div>
                <div class="cr-card cr-card-pend">
                    <div class="cr-card-t">PENDIENTE</div>
                    <div class="cr-card-n">@r.Pendiente.ToString("N0")</div>
                    <div class="cr-card-s">@VendidoSub(r)</div>
                </div>
                <div class="cr-card cr-card-packs">
                    <div class="cr-card-t">PACKS A REPONER</div>
                    <div class="cr-card-n @(r.Packs > 0 ? "cr-verde" : "")">@r.Packs</div>
                    <div class="cr-card-s">@PacksSub(r)</div>
                </div>
                <div class="cr-card cr-veredicto @VeredictoClase(r)">
                    <div class="cr-vtxt">@VeredictoTexto(r)</div>
                </div>
            </div>

            <div class="table-responsive cr-mov">
                <table class="market-table align-middle">
                    <thead><tr><th>Fecha</th><th>Hora</th><th>Comprobante</th><th class="text-center">Mot.</th><th class="text-end">Cant.</th><th class="text-end">Saldo</th><th class="text-center">Origen</th><th>Movimiento</th></tr></thead>
                    <tbody>
                        @foreach (var m in _d.Movimientos)
                        {
                            <tr class="@MovClase(m)" @onclick="() => AbrirEvento(m)" style="@(m.EventoId > 0 ? "cursor:pointer" : "")">
                                <td class="small">@(m.Fecha?.ToString("dd/MM/yyyy") ?? "")</td>
                                <td class="small">@m.Hora</td>
                                <td class="small">@m.Remito</td>
                                <td class="text-center small">@m.Motivo</td>
                                <td class="text-end fw-bold @(m.Cantidad < 0 ? "cr-rojo" : "")">@(m.Cantidad is null ? "" : ((int)m.Cantidad).ToString("N0"))</td>
                                <td class="text-end fw-bold @SaldoClase(m, r.CantPack)">@(m.Saldo?.ToString("N0") ?? "")</td>
                                <td class="text-center small">@m.Origen</td>
                                <td class="small">
                                    @m.Tipo
                                    @if (m.EventoId > 0) { <i class="fa-solid fa-image ms-1 text-muted" title="Ver detalle/foto del evento"></i> }
                                    @if (m.Orden == 1)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary cr-reset-btn" @onclick:stopPropagation="true" @onclick="() => AbrirReset(m)" title="Resetear este artículo desde este remito">
                                            <i class="fa-solid fa-rotate-left"></i> Resetear
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="cr-footer">@FooterTexto(r) @if (!_d.SaldoCuadra) { <span class="badge text-bg-danger ms-2">saldo no cuadra</span> }</div>
        </fieldset>
    }
    else if (_busco)
    {
        <div class="market-empty"><i class="fa-solid fa-magnifying-glass-chart"></i><p>Sin datos para ese artículo en ese local.</p></div>
    }
</div>

@if (_modalEvt && _evt is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Evento de piso: @_evt.TipoDiferencia — @_evt.Local</h5>
                    <button type="button" class="btn-close" @onclick="() => _modalEvt = false"></button>
                </div>
                <div class="modal-body">
                    <div class="small text-muted mb-3">
                        <span>Fecha: @_evt.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                        @if (!string.IsNullOrEmpty(_evt.CantidadPacks)) { <span> · Cant. packs: @_evt.CantidadPacks</span> }
                        @if (!string.IsNullOrEmpty(_evt.Usuario)) { <span> · Usuario: @_evt.Usuario</span> }
                        <span> · @(_evt.Procesado ? "PROCESADO" : "PENDIENTE")</span>
                    </div>
                    @if (_evt.TieneFoto)
                    {
                        <a href="@($"api/eventos/{_evt.Id}/foto")" target="_blank" rel="noopener">
                            <img src="@($"api/eventos/{_evt.Id}/foto")" class="cr-foto" alt="Foto del evento" />
                        </a>
                    }
                    else
                    {
                        <p class="text-muted small">Sin foto.</p>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_modalReset && _resetMov is not null && _d is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-rotate-left me-2"></i>Resetear desde remito</h5>
                    <button type="button" class="btn-close" @onclick="() => _modalReset = false"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">
                        Vas a re-anclar <strong>@_d.ArtCod</strong> en <strong>@_d.Local</strong> al remito
                        <strong>@_resetMov.Remito</strong> del <strong>@(_resetMov.Fecha?.ToString("dd/MM/yyyy")) @_resetMov.Hora</strong>.
                    </p>
                    <p class="small text-muted mb-3">
                        Cantidad del remito: @(((int)Math.Abs(_resetMov.Cantidad ?? 0)).ToString("N0")) u. · Pack: @_d.Resumen.CantPack
                        → <strong>@PacksReset(_resetMov) pack(s)</strong>.<br />
                        La ancla del artículo se mueve a esa fecha/hora y el pendiente queda en cero. La venta se vuelve a contar desde ahí.
                    </p>
                    <label class="form-label">Comentario (opcional)</label>
                    <input class="form-control" @bind="_resetComentario" maxlength="400" placeholder="Motivo del reseteo..." />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _modalReset = false">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarReset" disabled="@_reseteando">
                        @if (_reseteando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                        Resetear
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private string _local = "LURO";
    private string _artCod = "";
    private bool _cargando, _busco;
    private ExplicarDto? _d;

    private bool _modalEvt;
    private EventoDetalleDto? _evt;

    private bool _modalReset, _reseteando;
    private ExplicarMovimientoDto? _resetMov;
    private string _resetComentario = "";

    private const string StateKey = "consulta-reposicion";

    private sealed class Snap
    {
        public string Local = "LURO";
        public string ArtCod = "";
        public ExplicarDto? D;
        public bool Busco;
    }

    protected override void OnInitialized()
    {
        // Restaura la última consulta al volver (ej. desde la ficha del artículo) sin re-correr el SP.
        if (State.TryGet<Snap>(StateKey, out var s, out _))
        {
            _local = s.Local;
            _artCod = s.ArtCod;
            _d = s.D;
            _busco = s.Busco;
        }
    }

    private async Task OnKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Buscar(); }

    private async Task Buscar()
    {
        if (string.IsNullOrWhiteSpace(_artCod)) return;
        _cargando = true; _busco = true;
        try { _d = await Api.ExplicarAsync(_local, _artCod.Trim()); }
        catch { _d = null; }
        finally { _cargando = false; }
        State.Save(StateKey, new Snap { Local = _local, ArtCod = _artCod, D = _d, Busco = _busco }, 0);
    }

    private async Task AbrirEvento(ExplicarMovimientoDto m)
    {
        if (m.EventoId <= 0) return;
        _evt = await EventosApi.DetalleAsync(m.EventoId);
        if (_evt is not null) _modalEvt = true;
    }

    private int PacksReset(ExplicarMovimientoDto m)
    {
        var cp = _d?.Resumen.CantPack ?? 1;
        if (cp <= 0) cp = 1;
        var cant = (int)Math.Abs(m.Cantidad ?? 0);
        return Math.Max(1, (int)Math.Round(cant / (double)cp));
    }

    private void AbrirReset(ExplicarMovimientoDto m)
    {
        _resetMov = m;
        _resetComentario = "";
        _modalReset = true;
    }

    private async Task ConfirmarReset()
    {
        if (_resetMov is null || _d is null) return;
        _reseteando = true;
        var res = await Api.ResetearDesdeRemitoAsync(new ResetRemitoRequest
        {
            Local = _d.Local,
            ArtCod = _d.ArtCod,
            Remito = _resetMov.Remito,
            Fecha = _resetMov.Fecha ?? DateTime.Today,
            Hora = _resetMov.Hora,
            Cantidad = (int)Math.Abs(_resetMov.Cantidad ?? 0),
            CantPack = _d.Resumen.CantPack,
            Comentario = _resetComentario
        });
        _reseteando = false;
        await JS.InvokeVoidAsync("alert", res.Mensaje);
        if (res.Ok) { _modalReset = false; await Buscar(); }
    }

    // ---- Presentación (porteo de frmRepoConsultaArticulo) ----

    private static string VeredictoTexto(ExplicarResumenDto r)
    {
        if (!r.HayDatos) return "SIN DATOS";
        if (r.Packs > 0)
        {
            var verbo = r.Clasificacion.ToUpperInvariant().StartsWith("REEMPLAZO") ? "REEMPLAZAR" : "REPONER";
            return $"{verbo} {r.Packs} PACK" + (r.Packs == 1 ? "" : "S");
        }
        return "STOCK OK";
    }

    private static string VeredictoClase(ExplicarResumenDto r)
        => !r.HayDatos ? "cr-v-sin" : r.Packs > 0 ? "cr-v-rep" : "cr-v-ok";

    private static bool PackRoto(ExplicarResumenDto r)
        => r.UltRemitoCant > 0 && r.CantPack > 0 && (r.UltRemitoCant % r.CantPack) != 0;

    private static string PackSub(ExplicarResumenDto r)
        => PackRoto(r) ? $"Últ. remito: {r.UltRemitoCant:N0} u." : $"(Repo neto: {r.ReposEnviadas})";

    private static string VendidoSub(ExplicarResumenDto r)
    {
        var desde = r.Ancla is null ? "desde el ancla" : "desde " + r.Ancla.Value.ToString("dd/MM/yyyy");
        return $"Vendido {desde}: {r.Venta:N0}" + (r.FallasRotacion > 0 ? $" · Fallas+Rot: {r.FallasRotacion:N0}" : "");
    }

    private static string PacksSub(ExplicarResumenDto r)
        => $"(Pendiente: {r.Pendiente} · Pack={r.CantPack})";

    private static string FooterTexto(ExplicarResumenDto r)
    {
        var p = new List<string> { "VENDIDO: " + r.Venta };
        if (r.FallasRotacion != 0) p.Add("FALLAS+ROT: " + r.FallasRotacion);
        if (r.Ajuste != 0) p.Add("AJUSTE: " + r.Ajuste);
        if (r.ReposEnviadas != 0) p.Add("REPOS NETO: " + r.ReposEnviadas);
        if (r.SobranteAplicadoUnidades > 0)
            p.Add($"SOBRANTE LOCAL: -{r.SobranteAplicadoUnidades:N0} ({r.SobranteAplicadoPacks:N0} pack{(r.SobranteAplicadoPacks == 1 ? "" : "s")})");
        return string.Join(" · ", p) + "   →   PENDIENTE: " + r.Pendiente;
    }

    private static string MovClase(ExplicarMovimientoDto m) => m.Orden switch
    {
        0 => "cr-m-ancla",
        1 => m.Tipo.Contains("Refuerzo dia", StringComparison.OrdinalIgnoreCase) ? "cr-m-refuerzo" : "cr-m-noche",
        2 => m.SaldoDelta == 0 ? "cr-m-rot-huerfana" : "cr-m-rot",
        3 => "cr-m-falla",
        5 => "cr-m-ajuste",
        6 => m.Tipo.Contains("[sin visar]", StringComparison.OrdinalIgnoreCase) ? "cr-m-evt-pend" : "cr-m-evt",
        8 or 9 => "cr-m-resumen",
        _ => ""
    };

    private static string SaldoClase(ExplicarMovimientoDto m, int cantPack)
    {
        if (m.Saldo is null) return "";
        if (cantPack > 0 && m.Saldo >= cantPack) return "cr-rojo";
        if (m.Saldo > 0) return "cr-verde";
        if (m.Saldo < 0) return "text-muted";
        return "";
    }
}
