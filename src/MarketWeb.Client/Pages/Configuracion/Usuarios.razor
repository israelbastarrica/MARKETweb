@page "/configuracion/usuarios"
@inject UsuariosPcApi Api
@inject UiService Ui

<PageTitle>Usuarios</PageTitle>

<div class="market-page">
    <PageHeader Modulo="Configuración" Titulo="Usuarios" Icono="fa-solid fa-users" />

    <p class="text-muted market-hint" style="margin-top:-.6rem">
        Asignación de <strong>perfil por PC</strong>. El perfil define qué módulos ve cada máquina.
    </p>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div class="input-group" style="max-width: 420px">
            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input class="form-control" placeholder="Buscar por PC o perfil..."
                   @bind="_filtro" @bind:event="oninput" @onkeyup="OnFiltroKeyUp" />
            <button class="btn btn-outline-secondary" @onclick="Buscar">Buscar</button>
        </div>
        <button class="btn btn-primary" @onclick="AbrirAlta">
            <i class="fa-solid fa-plus me-1"></i> Agregar
        </button>
    </div>

    @if (_mensaje is not null)
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @_mensaje
            <button type="button" class="btn-close" @onclick="() => _mensaje = null"></button>
        </div>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Cargar">Reintentar</button>
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_usuarios.Count == 0)
    {
        <div class="market-empty">
            <i class="fa-solid fa-users-slash"></i>
            <p>No se encontraron registros.</p>
        </div>
    }
    else
    {
        <div class="market-card table-responsive">
            <table class="market-table align-middle">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th style="width: 26%">PC</th>
                        <th style="width: 160px">Perfil</th>
                        <th style="width: 110px" class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in _usuarios)
                    {
                        <tr @ondblclick="() => AbrirModificacion(u)">
                            <td>
                                @if (!string.IsNullOrWhiteSpace(u.Mail))
                                {
                                    <div class="market-user">
                                        <span class="nombre">
                                            @NombreDesdeMail(u.Mail)
                                            @if (!u.MailAprobado)
                                            {
                                                <span class="badge-pend">pendiente</span>
                                            }
                                        </span>
                                        <span class="sub">@u.Mail</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="market-user">
                                        <span class="nombre">@u.Pc</span>
                                        <span class="sub"><i class="fa-solid fa-desktop me-1"></i>identificado por PC</span>
                                    </div>
                                }
                            </td>
                            <td>@if (EsWebRequest(u)) { <span class="text-muted">—</span> } else { @u.Pc }</td>
                            <td><span class="badge-perfil">@u.Perfil</span></td>
                            <td class="text-center text-nowrap acciones">
                                @* PC reclamada y pendiente: tilde directo (el perfil ya está bien).
                                   Solicitud web: SIN tilde directo → hay que abrir y aprobar eligiendo el perfil. *@
                                @if (!string.IsNullOrWhiteSpace(u.Mail) && !u.MailAprobado && !EsWebRequest(u))
                                {
                                    <button class="btn btn-sm btn-outline-success me-1" title="Aprobar acceso"
                                            @onclick="() => Aprobar(u)">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                }
                                <button class="btn btn-sm me-1 @(EsWebRequest(u) && !u.MailAprobado ? "btn-outline-success" : "btn-outline-primary")"
                                        title="@(EsWebRequest(u) && !u.MailAprobado ? "Revisar y aprobar" : "Modificar")"
                                        @onclick="() => AbrirModificacion(u)">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" title="Eliminar"
                                        @onclick="() => Eliminar(u)">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">@_usuarios.Count registro(s).</p>
    }
</div>

@if (_modalAbierto)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <EditForm Model="_editado" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />
                    <div class="modal-header">
                        <h5 class="modal-title">@(_esAlta ? "Nueva PC" : (_esWebRequest ? "Revisar solicitud web" : "Modificar PC"))</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <div class="modal-body">
                        @if (_errorModal is not null)
                        {
                            <div class="alert alert-danger py-2">@_errorModal</div>
                        }
                        @if (_esWebRequest)
                        {
                            <div class="alert alert-info py-2 d-flex align-items-center">
                                <i class="fa-solid fa-globe me-2"></i>
                                <div>Solicitud por la web (sin PC). Revisá el <strong>perfil</strong> y aprobá.</div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">PC (nombre de la máquina)</label>
                                <InputText class="form-control" @bind-Value="_editado.Pc" placeholder="Ej: DESKTOP-XXXXXX" />
                                <ValidationMessage For="() => _editado.Pc" />
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Mail <span class="text-muted">(@@marketarg.com)</span></label>
                            <InputText class="form-control" type="email" @bind-Value="_editado.Mail"
                                       placeholder="usuario@marketarg.com" />
                            <ValidationMessage For="() => _editado.Mail" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Perfil</label>
                            <InputText class="form-control" list="perfiles" @bind-Value="_editado.Perfil"
                                       placeholder="Elegí uno o escribí uno nuevo" />
                            <datalist id="perfiles">
                                @foreach (var p in _perfiles)
                                {
                                    <option value="@p" />
                                }
                            </datalist>
                            <ValidationMessage For="() => _editado.Perfil" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@_guardando">
                            @if (_guardando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                            @(_esWebRequest ? "Aprobar" : "Guardar")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<UsuarioPcDto> _usuarios = new();
    private List<string> _perfiles = new();
    private string _filtro = "";
    private bool _cargando = true;
    private string? _mensaje;
    private string? _error;

    private bool _modalAbierto;
    private bool _esAlta;
    private bool _esWebRequest;
    private bool _guardando;
    private int _idEditado;
    private string? _errorModal;
    private UsuarioPcSaveRequest _editado = new();

    // Solicitud por la web: la guardo con PC = Mail (no tiene PC física). Esas hay
    // que abrirlas y aprobarlas eligiendo el perfil (sin tilde de aprobación directa).
    private static bool EsWebRequest(UsuarioPcDto u)
        => !string.IsNullOrWhiteSpace(u.Mail) && string.Equals(u.Pc, u.Mail, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await CargarPerfiles();
        await Cargar();
    }

    private async Task CargarPerfiles()
    {
        try { _perfiles = await Api.ListarPerfilesAsync(); }
        catch { _perfiles = new(); }
    }

    private async Task Cargar()
    {
        _cargando = true;
        _error = null;
        try
        {
            _usuarios = await Api.ListarAsync(_filtro);
        }
        catch (Exception ex)
        {
            _usuarios = new();
            _error = "No se pudieron cargar los usuarios. Verificá la conexión a la base de datos.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _cargando = false;
        }
    }

    private Task Buscar() => Cargar();

    // El "nombre de usuario" del gmail = la parte antes de @ (ej: israelbastarrica).
    // Cuando tengamos el login de Google, el nombre real (display name) vendrá del token.
    private static string NombreDesdeMail(string? mail) => (mail ?? "").Split('@')[0];

    private async Task OnFiltroKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Cargar();
    }

    private void AbrirAlta()
    {
        _esAlta = true;
        _esWebRequest = false;
        _idEditado = 0;
        _editado = new UsuarioPcSaveRequest();
        _errorModal = null;
        _modalAbierto = true;
    }

    private void AbrirModificacion(UsuarioPcDto u)
    {
        _esAlta = false;
        _esWebRequest = EsWebRequest(u) && !u.MailAprobado;
        _idEditado = u.Id;
        _editado = new UsuarioPcSaveRequest { Pc = u.Pc, Perfil = u.Perfil, Mail = u.Mail };
        _errorModal = null;
        _modalAbierto = true;
    }

    private void CerrarModal() => _modalAbierto = false;

    private async Task Guardar()
    {
        _guardando = true;
        _errorModal = null;

        var (ok, error) = _esAlta
            ? await Api.CrearAsync(_editado)
            : await Api.ModificarAsync(_idEditado, _editado);

        _guardando = false;

        if (!ok)
        {
            _errorModal = error;
            return;
        }

        _modalAbierto = false;
        _mensaje = _esAlta ? "Registro agregado correctamente."
            : _esWebRequest ? "Acceso aprobado correctamente."
            : "Registro modificado correctamente.";
        await CargarPerfiles();
        await Cargar();
    }

    private async Task Eliminar(UsuarioPcDto u)
    {
        var confirma = await Ui.ConfirmAsync($"¿Está seguro de eliminar la PC \"{u.Pc}\"?", "Eliminar PC", "Eliminar", "Cancelar", peligro: true);
        if (!confirma) return;

        await Api.EliminarAsync(u.Id);
        _mensaje = "Registro eliminado correctamente.";
        await Cargar();
    }

    private async Task Aprobar(UsuarioPcDto u)
    {
        var confirma = await Ui.ConfirmAsync($"¿Aprobar el acceso de {u.Mail} (PC {u.Pc}, perfil {u.Perfil})?", "Aprobar acceso");
        if (!confirma) return;

        await Api.AprobarAsync(u.Id);
        _mensaje = "Acceso aprobado correctamente.";
        await Cargar();
    }
}
