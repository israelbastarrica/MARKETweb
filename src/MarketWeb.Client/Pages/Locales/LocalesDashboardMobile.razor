@implements IDisposable
@using System.Globalization
@using MarketWeb.Shared.Dashboard
@inject DashboardApi Api

@* Vista mobile del dashboard de Locales (ventas). Dos versiones, igual que la TV:
   - cajero: enfocado en el AVANCE del día (tickets reales vs proyectados).
   - admin: gerencial (ambos locales, top productos, cajeros). *@

<div class="vm">
    <div class="vm-head">
        <div>
            <div class="vm-eyebrow">Locales</div>
            <div class="vm-title">Ventas hoy</div>
        </div>
        <button class="vm-refresh" @onclick="Refrescar" disabled="@_cargando" title="Actualizar">
            <i class="fa-solid @(_cargando ? "fa-spinner fa-spin" : "fa-rotate")"></i>
        </button>
    </div>

    @if (_error is not null)
    {
        <div class="vm-error"><i class="fa-solid fa-triangle-exclamation me-2"></i>@_error</div>
    }

    @if (_data is not null)
    {
        @foreach (var l in _data.Locales)
        {
            @if (_data.Role == "cajero")
            {
                @* ---- Versión cajero: avance vs proyección (SIN plata) ---- *@
                <div class="vm-card">
                    <div class="vm-card-head">
                        <span class="vm-local">@l.Local</span>
                    </div>

                    @if (l.ProyTicketsAhora is int proyAhora)
                    {
                        var diff = l.Tickets - proyAhora;
                        var ok = diff >= 0;
                        <div class="vm-avance @(ok ? "ok" : "bad")">
                            <span class="big">@l.Tickets</span>
                            <span class="lab">tickets hoy</span>
                            <span class="cmp">
                                <i class="fa-solid @(ok ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i>
                                @(diff >= 0 ? "+" : "")@diff vs proyectado a esta hora (@proyAhora)
                            </span>
                        </div>
                        @if (l.ProyTicketsDia is int proyDia && proyDia > 0)
                        {
                            var pct = (double)l.Tickets / proyDia * 100;
                            <div class="vm-prog"><span style="width:@(Math.Min(100, pct).ToString("0", CultureInfo.InvariantCulture))%"></span></div>
                            <div class="vm-progleg">
                                <span>@l.Tickets de @proyDia proyectados hoy</span>
                                <span>@Pct(pct)</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="vm-avance">
                            <span class="big">@l.Tickets</span>
                            <span class="lab">tickets hoy</span>
                            <span class="cmp">sin proyección cargada</span>
                        </div>
                    }

                    <div class="vm-kpis k2">
                        <div><span class="n">@Miles(l.Prendas)</span><span class="t">Prendas</span></div>
                        <div><span class="n">@PrendasPorTicket(l)</span><span class="t">Prendas x ticket</span></div>
                    </div>

                    @if (l.Cajeros.Count > 0)
                    {
                        <div class="vm-sub">Cajeros</div>
                        <div class="vm-chips">
                            @foreach (var c in l.Cajeros) { <span>@c.Nombre <b>@c.Tickets</b></span> }
                        </div>
                    }
                </div>
            }
            else
            {
                @* ---- Versión admin: gerencial ---- *@
                <div class="vm-card">
                    <div class="vm-card-head">
                        <span class="vm-local">@l.Local</span>
                        <span class="vm-monto">@Miles(l.Monto)</span>
                    </div>
                    <div class="vm-kpis">
                        <div><span class="n">@l.Tickets</span><span class="t">Tickets</span></div>
                        <div><span class="n">@Miles(l.Prendas)</span><span class="t">Prendas</span></div>
                        <div><span class="n">@Miles(TicketProm(l))</span><span class="t">Ticket prom.</span></div>
                    </div>

                    @if (l.TopArticulos.Count > 0)
                    {
                        <div class="vm-sub">Top productos</div>
                        <div class="vm-list">
                            @foreach (var a in l.TopArticulos)
                            {
                                <div class="vm-row">
                                    <span class="d"><b class="vm-cod">@a.Codigo</b> @a.Descripcion</span>
                                    <span class="q">@Miles(a.Cantidad)</span>
                                </div>
                            }
                        </div>
                    }

                    @if (l.Cajeros.Count > 0)
                    {
                        <div class="vm-sub">Cajeros</div>
                        <div class="vm-chips">
                            @foreach (var c in l.Cajeros) { <span>@c.Nombre <b>@c.Tickets</b></span> }
                        </div>
                    }
                </div>
            }
        }
    }

    @if (_cargando && _data is null)
    {
        <div class="vm-loading"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando ventas...</div>
    }

    <div class="vm-foot">Actualizado @(_data?.Actualizado ?? "—") · se refresca solo cada 60s</div>
</div>

@code {
    private DashboardVentasMobileDto? _data;
    private bool _cargando = true;
    private string? _error;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await Refrescar();
        _cts = new CancellationTokenSource();
        _ = AutoRefrescar(_cts.Token);
    }

    private async Task AutoRefrescar(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(60000, ct);
                await Refrescar();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task Refrescar()
    {
        _cargando = true; _error = null;
        try { _data = await Api.ResumenMobile(); }
        catch (Exception ex) { _error = "No se pudieron cargar las ventas."; Console.Error.WriteLine(ex); }
        finally { _cargando = false; }
    }

    private static decimal TicketProm(VentaLocalResumenDto l) => l.Tickets > 0 ? l.Monto / l.Tickets : 0;

    // Métrica operativa sin plata para la vista cajero (prendas vendidas por ticket).
    private static string PrendasPorTicket(VentaLocalResumenDto l)
        => l.Tickets > 0 ? (l.Prendas / l.Tickets).ToString("0.0", CultureInfo.InvariantCulture) : "0";

    private static string Pct(double d) => $"{Math.Round(d)}%";

    // Entero con separador de miles "." sin depender de la cultura del navegador.
    private static string Miles(decimal n)
    {
        var neg = n < 0;
        var e = ((long)Math.Truncate(Math.Abs(n))).ToString(CultureInfo.InvariantCulture);
        if (e.Length > 3)
        {
            var chars = e.ToCharArray();
            Array.Reverse(chars);
            var sb = new System.Text.StringBuilder();
            for (int i = 0; i < chars.Length; i++) { if (i > 0 && i % 3 == 0) sb.Append('.'); sb.Append(chars[i]); }
            var r = sb.ToString().ToCharArray();
            Array.Reverse(r);
            e = new string(r);
        }
        return (neg ? "-" : "") + e;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
