@page "/locales/dashboard"
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

@* En celular (pantalla angosta) mostramos una vista nativa con los KPIs de ventas;
   en pantalla grande, el dashboard de TV (NoblexTV) embebido en iframe. *@
@if (_mobile == true)
{
    <LocalesDashboardMobile />
}
else if (_mobile == false)
{
    <iframe src="@_src" class="dashboard-frame" title="Dashboard Market" allow="fullscreen" allowfullscreen></iframe>
}
else
{
    <p class="text-muted p-3"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
}

<style>
    .dashboard-frame {
        display: block;
        width: 100%;
        height: calc(100vh - 6rem);
        border: 0;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(16, 24, 40, .12);
        background: #0d1117;
    }
</style>

@code {
    private bool? _mobile;
    // Cache-bust: el dashboard.html es estático y se carga en iframe; sin esto el navegador
    // sirve la versión vieja tras un deploy. Token por carga → siempre trae el HTML fresco.
    private readonly string _src = $"dashboard.html?v={Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _mobile = await JS.InvokeAsync<bool>("esMobile"); }
            catch { _mobile = false; }   // ante la duda, TV
            StateHasChanged();
        }
    }
}
