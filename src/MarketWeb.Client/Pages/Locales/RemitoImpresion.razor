@page "/locales/remito-impresion"
@page "/logistica/remito-impresion"
@implements IDisposable
@inject RemitoImpresionApi Api
@inject IJSRuntime JS
@inject UiService Ui

<PageTitle>Remito Impresión</PageTitle>

<div class="market-page">
    <PageHeader Modulo="Locales" Titulo="Remito Impresión" Icono="fa-solid fa-print" />

    <div class="market-card p-3 mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Local origen</label>
                <select class="form-select form-select-sm" @bind="_local" @bind:after="Buscar" disabled="@_localFijo">
                    @if (!_localFijo) { <option value="TODOS">Todos</option> }
                    @foreach (var l in _locales) { <option value="@l">@l</option> }
                </select>
            </div>
            @if (_saltafwFijo is not null)
            {
                <div class="col-12 col-md-auto">
                    <label class="form-label small text-muted mb-1"><i class="fa-solid fa-print me-1"></i>Impresora</label>
                    <div class="d-flex align-items-center gap-2" style="height:31px">
                        <span class="badge text-bg-light border"><i class="fa-solid fa-desktop me-1"></i>@_miPc</span>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="chkTodosPc" @bind="_verTodos" @bind:after="Buscar" />
                            <label class="form-check-label small" for="chkTodosPc">Ver todos</label>
                        </div>
                    </div>
                </div>
            }
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Desde</label>
                <input type="date" class="form-control form-control-sm" @bind="_desde" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Hasta</label>
                <input type="date" class="form-control form-control-sm" @bind="_hasta" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Estado</label>
                <select class="form-select form-select-sm" @bind="_estado" @bind:after="Buscar" disabled="@_soloErrores">
                    <option value="TODOS">Todos</option>
                    <option value="PENDIENTE">Pendiente</option>
                    <option value="IMPRESO">Impreso</option>
                    <option value="ERROR">Error</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <div class="form-check mt-3">
                    <input class="form-check-input" type="checkbox" id="chkErr" @bind="_soloErrores" @bind:after="Buscar" />
                    <label class="form-check-label small" for="chkErr">Solo errores</label>
                </div>
            </div>
            <div class="col-6 col-md-2 d-flex">
                <button class="btn btn-primary btn-sm flex-grow-1" @onclick="Buscar">
                    <i class="fa-solid fa-magnifying-glass me-1"></i> Buscar
                </button>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-outline-danger btn-sm" @onclick="AbrirAnulados">
            <i class="fa-solid fa-ban me-1"></i> REMITOS ANULADOS
        </button>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Buscar">Reintentar</button>
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_remitos.Count == 0)
    {
        <div class="market-empty"><i class="fa-solid fa-print"></i><p>No hay remitos en la cola para el período.</p></div>
    }
    else
    {
        <div class="market-card table-responsive">
            <table class="market-table align-middle">
                <thead>
                    <tr>
                        <th style="width: 130px">Estado</th>
                        <th>Nro Remito</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Emisión</th>
                        <th>Detectado</th>
                        <th>Impreso</th>
                        <th class="text-center">Int.</th>
                        <th>IP</th>
                        <th>Error</th>
                        <th style="width: 200px" class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _remitos)
                    {
                        <tr class="@FilaClase(r.Estado)">
                            <td><span class="badge @BadgeClase(r.Estado)">@r.Estado</span></td>
                            <td class="fw-semibold">@r.NroRemito</td>
                            <td>@r.LocalOrigen</td>
                            <td>@r.LocalDestino</td>
                            <td class="small">@r.FechaEmision.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="small">@r.FechaDetectado.ToString("dd/MM HH:mm:ss")</td>
                            <td class="small">@(r.FechaImpreso?.ToString("dd/MM HH:mm:ss") ?? "—")</td>
                            <td class="text-center">@r.Intentos</td>
                            <td class="small text-muted">@r.IpImpresora</td>
                            <td class="small text-danger">@r.ErrorMsg</td>
                            <td class="text-center text-nowrap">
                                <button class="btn btn-sm btn-outline-primary me-1" title="Reimprimir" disabled="@(_seguimiento.Contains(r.Id))"
                                        @onclick="() => Reimprimir(r)">
                                    @if (_seguimiento.Contains(r.Id)) { <i class="fa-solid fa-spinner fa-spin"></i> }
                                    else { <i class="fa-solid fa-print me-1"></i> }
                                    Reimprimir
                                </button>
                                <button class="btn btn-sm btn-outline-danger" title="Anular y pedir rechazo en el local"
                                        @onclick="() => Anular(r)">
                                    <i class="fa-solid fa-ban me-1"></i> Anular
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">@_remitos.Count remito(s)@(_seguimiento.Count > 0 ? $" · {_seguimiento.Count} en cola..." : "").</p>
    }
</div>

@if (_modalAnular && _anularRemito is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fa-solid fa-triangle-exclamation me-2"></i>Anular remito</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _modalAnular = false"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">
                        Vas a anular el remito <strong>@_anularRemito.NroRemito</strong> hacia <strong>@_anularRemito.LocalDestino</strong>.
                    </p>
                    <div class="alert alert-danger mb-0">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        Esto pide que <strong>@_anularRemito.LocalDestino</strong> lo <strong>RECHACE</strong> y el stock <strong>vuelve al depósito</strong>.
                        La acción es delicada y afecta stock real. ¿Seguro?
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _modalAnular = false">No, cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmarAnular" disabled="@_anulando">
                        @if (_anulando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                        else { <i class="fa-solid fa-ban me-1"></i> }
                        Sí, anular y pedir rechazo
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_modalAnulados)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-ban me-2 text-danger"></i>Remitos anulados</h5>
                    <button type="button" class="btn-close" @onclick="() => _modalAnulados = false"></button>
                </div>
                <div class="modal-body">
                    @if (_cargandoAnulados)
                    {
                        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
                    }
                    else if (_anulados.Count == 0)
                    {
                        <div class="market-empty"><i class="fa-solid fa-ban"></i><p>No hay remitos anulados en el período.</p></div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="market-table align-middle">
                                <thead>
                                    <tr>
                                        <th style="width: 150px">Rechazo</th>
                                        <th>Nro Remito</th>
                                        <th>Origen</th>
                                        <th>Destino</th>
                                        <th>Emisión</th>
                                        <th>Anulado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _anulados)
                                    {
                                        <tr class="fila-anulado">
                                            <td><span class="badge @BadgeRechazoClase(r.EstadoRechazo)">@TextoRechazo(r.EstadoRechazo)</span></td>
                                            <td class="fw-semibold">@r.NroRemito</td>
                                            <td>@r.LocalOrigen</td>
                                            <td>@r.LocalDestino</td>
                                            <td class="small">@r.FechaEmision.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="small">@(r.FechaAnulado?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <p class="text-muted small">@_anulados.Count remito(s) anulado(s).</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _modalAnulados = false">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<style>
    tr.fila-imp { }
    tr.fila-pen { background: #eef4ff !important; }
    tr.fila-err { background: #fdeaea !important; }
    .badge-imp { background: #198754; }
    .badge-pen { background: #0d6efd; }
    .badge-err { background: #dc3545; }

    tr.fila-anulado { background: #fdeaea !important; }

    /* Modo oscuro: tintes oscuros legibles (el pastel claro no se leía con texto claro). */
    html[data-theme="dark"] tr.fila-pen { background: rgba(56, 130, 246, .16) !important; }
    html[data-theme="dark"] tr.fila-err { background: rgba(214, 80, 70, .18) !important; }
    html[data-theme="dark"] tr.fila-anulado { background: rgba(214, 80, 70, .18) !important; }
</style>

@code {
    private List<string> _locales = new();
    private string _local = "TODOS";
    private bool _localFijo;
    private DateTime _desde = DateTime.Today;   // arranca con lo del día (lo que se ve y reimprime)
    private DateTime _hasta = DateTime.Today;
    private string _estado = "TODOS";
    private bool _soloErrores;

    // Impresora fija por equipo: mapeo "Esta PC" → SALTAFW (usuario/terminal de Dragon), igual que el .Net.
    // La PC se identifica con el nombre de "Esta PC" (localStorage marketweb.pc, el del chip de la barra).
    private static readonly Dictionary<string, int> _saltafwPorPc = new(StringComparer.OrdinalIgnoreCase)
    {
        ["DESKTOP-4MMOK3S"] = 809131,
        ["DESKTOP-1DR5A7F"] = 809129,
    };
    private string _miPc = "";
    private int? _saltafwFijo;   // null = esta PC no tiene impresora asignada → ve todo
    private bool _verTodos;      // override para ver la cola completa

    private List<RemitoColaDto> _remitos = new();
    private bool _cargando = true;
    private string? _error;

    private bool _modalAnular, _anulando;
    private RemitoColaDto? _anularRemito;

    private bool _modalAnulados, _cargandoAnulados;
    private List<RemitoColaDto> _anulados = new();

    private readonly HashSet<int> _seguimiento = new();
    private CancellationTokenSource? _pollCts;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try { _locales = await Api.ListarLocalesAsync(); }
        catch (Exception ex) { _error = "No se pudieron cargar los locales."; Console.Error.WriteLine(ex); }

        string? perfil = null;
        if (AuthState is not null)
        {
            var state = await AuthState;
            perfil = state.User.FindFirst("perfil")?.Value;
        }
        // Local → su origen; LOGISTICA → CENTRAL; ADMIN → combo libre.
        var scopeName = string.Equals(perfil, "LOGISTICA", StringComparison.OrdinalIgnoreCase) ? "CENTRAL" : perfil;
        var propio = _locales.FirstOrDefault(l => string.Equals(l, scopeName, StringComparison.OrdinalIgnoreCase));
        if (propio is not null) { _local = propio; _localFijo = true; }

        // Impresora fija de ESTE equipo según su "Esta PC" (el nombre del chip de la barra).
        try { _miPc = await JS.InvokeAsync<string>("localStorage.getItem", DevicePcState.KeyNombre) ?? ""; } catch { _miPc = ""; }
        if (!string.IsNullOrWhiteSpace(_miPc) && _saltafwPorPc.TryGetValue(_miPc.Trim(), out var sf)) _saltafwFijo = sf;

        await Buscar();
    }

    private async Task Buscar()
    {
        _cargando = true; _error = null;
        // Si esta PC tiene impresora asignada y no se pidió "ver todos", filtramos por su SALTAFW.
        int? saltafw = (_saltafwFijo is int s && !_verTodos) ? s : null;
        try { _remitos = await Api.ListarAsync(_desde, _hasta, _local, _estado, _soloErrores, saltafw); }
        catch (Exception ex) { _remitos = new(); _error = "No se pudo cargar la cola de impresión."; Console.Error.WriteLine(ex); }
        finally { _cargando = false; }
    }

    private async Task Reimprimir(RemitoColaDto r)
    {
        var confirma = await Ui.ConfirmAsync($"¿Re-encolar el remito {r.NroRemito} ({r.LocalDestino}) para reimprimir?", "Reimprimir");
        if (!confirma) return;

        var ok = await Api.ReimprimirAsync(r.Id);
        if (!ok) { _error = "No se pudo re-encolar el remito."; return; }

        // Marca visual inmediata + seguimiento en tiempo real.
        r.Estado = "PENDIENTE";
        r.Intentos = 0;
        r.ErrorMsg = null;
        r.FechaImpreso = null;
        _seguimiento.Add(r.Id);
        ArrancarPolling();
    }

    private void Anular(RemitoColaDto r)
    {
        _anularRemito = r;
        _modalAnular = true;
    }

    private async Task ConfirmarAnular()
    {
        if (_anularRemito is null) return;
        // El modal rojo de arriba ya es la confirmación deliberada (acción delicada, mueve stock real).
        var nro = _anularRemito.NroRemito;
        _anulando = true;
        var ok = await Api.AnularAsync(_anularRemito.Id);
        _anulando = false;
        _modalAnular = false;
        if (ok)
        {
            // Sale de la cola principal y pasa a la lista de anulados.
            _remitos.RemoveAll(x => x.Id == _anularRemito?.Id);
            Ui.Exito($"Remito {nro}: marcado para rechazo. El agente lo rechazará cuando el local lo tenga sincronizado.");
        }
        else Ui.Error("No se pudo anular el remito.");
        _anularRemito = null;
    }

    private async Task AbrirAnulados()
    {
        _modalAnulados = true;
        _cargandoAnulados = true;
        _anulados = new();
        // Mismo contexto que la cola: período, local e impresora de esta PC (salvo "ver todos").
        int? saltafw = (_saltafwFijo is int s && !_verTodos) ? s : null;
        try { _anulados = await Api.ListarAnuladosAsync(_desde, _hasta, _local, saltafw); }
        catch (Exception ex) { Ui.Error("No se pudieron cargar los remitos anulados."); Console.Error.WriteLine(ex); }
        finally { _cargandoAnulados = false; }
    }

    private static string TextoRechazo(string? estado) => estado switch
    {
        "RECHAZADO_OK" => "Rechazado",
        "PENDIENTE_API" => "Pendiente",
        null or "" => "Anulado",
        _ => estado
    };

    private static string BadgeRechazoClase(string? estado) => estado switch
    {
        "RECHAZADO_OK" => "bg-danger",
        "PENDIENTE_API" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private void ArrancarPolling()
    {
        if (_pollCts is not null) return; // ya corriendo
        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested && _seguimiento.Count > 0)
            {
                await Task.Delay(3000, ct);
                var estados = await Api.EstadoAsync(_seguimiento.ToArray());
                foreach (var e in estados)
                {
                    var r = _remitos.FirstOrDefault(x => x.Id == e.Id);
                    if (r is not null)
                    {
                        r.Estado = e.Estado;
                        r.Intentos = e.Intentos;
                        r.FechaImpreso = e.FechaImpreso;
                        r.ErrorMsg = e.ErrorMsg;
                    }
                    if (!string.Equals(e.Estado, "PENDIENTE", StringComparison.OrdinalIgnoreCase))
                        _seguimiento.Remove(e.Id);
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Console.Error.WriteLine(ex); }
        finally
        {
            _pollCts?.Dispose();
            _pollCts = null;
        }
    }

    private static string FilaClase(string estado) => estado switch
    {
        "PENDIENTE" => "fila-pen",
        "ERROR" => "fila-err",
        _ => "fila-imp"
    };

    private static string BadgeClase(string estado) => estado switch
    {
        "PENDIENTE" => "badge-pen",
        "ERROR" => "badge-err",
        _ => "badge-imp"
    };

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
