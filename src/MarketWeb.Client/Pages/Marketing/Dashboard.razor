@page "/marketing/dashboard"
@using MarketWeb.Shared.Marketing
@inject MarketingApi Api

<PageTitle>Marketing — Dashboard</PageTitle>

<div class="market-page">
    <PageHeader Modulo="Marketing" Titulo="Dashboard" Icono="fa-solid fa-chart-line" Compartible="false" />
    <p class="text-muted market-hint" style="margin-top:-.6rem">
        Resumen de contenido de Instagram y Facebook (insights de cuenta).
        @if (_d?.Hasta is not null) { <text>Período al @_d.Hasta?.ToString("dd/MM/yyyy") (últimos ~28 días).</text> }
    </p>

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_d is null || _d.Hasta is null)
    {
        <div class="market-empty">
            <i class="fa-solid fa-chart-line"></i>
            <p>Todavía no hay insights de cuenta cargados.</p>
            <p class="small text-muted mb-0">Se llenan cuando corre el colector de insights (Meta).</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-6 col-lg-3">
                <div class="market-card mk-kpi h-100">
                    <div class="mk-kpi-head">
                        <span class="mk-kpi-ico" style="background:#E1306C"><i class="fa-brands fa-instagram"></i></span>
                        <span class="mk-kpi-label">Visualizaciones IG</span>
                    </div>
                    <div class="mk-kpi-val">@Abrev(_d.VisualizacionesIG)@Flecha(_d.VisualizacionesIG, _d.VisualizacionesPrevIG)</div>
                    <div class="mk-kpi-sub">vistas del período</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="market-card mk-kpi h-100">
                    <div class="mk-kpi-head">
                        <span class="mk-kpi-ico" style="background:#0F6E56"><i class="fa-solid fa-eye"></i></span>
                        <span class="mk-kpi-label">Alcance</span>
                    </div>
                    <div class="mk-kpi-val">@Abrev(_d.Alcance)@Flecha(_d.Alcance, _d.AlcancePrev)</div>
                    <div class="mk-kpi-sub">seg. @Abrev(_d.AlcanceSeguidores) · no seg. @Abrev(_d.AlcanceNoSeguidores)</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="market-card mk-kpi h-100">
                    <div class="mk-kpi-head">
                        <span class="mk-kpi-ico" style="background:#7C3AED"><i class="fa-solid fa-heart"></i></span>
                        <span class="mk-kpi-label">Interacciones</span>
                    </div>
                    <div class="mk-kpi-val">@Abrev(_d.Interacciones)@Flecha(_d.Interacciones, _d.InteraccionesPrev)</div>
                    <div class="mk-kpi-sub">cuentas alcanzadas @Abrev(_d.CuentasAlcanzadas)</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="market-card mk-kpi h-100">
                    <div class="mk-kpi-head">
                        <span class="mk-kpi-ico" style="background:#1877F2"><i class="fa-brands fa-facebook"></i></span>
                        <span class="mk-kpi-label">Facebook</span>
                    </div>
                    <div class="mk-kpi-val">@Abrev(_d.FbInteracciones)@Flecha(_d.FbInteracciones, _d.FbInteraccionesPrev)</div>
                    <div class="mk-kpi-sub">
                        <span class="text-success">+@(_d.FbSeguidoresNuevos ?? 0)</span> /
                        <span class="text-danger">-@(_d.FbDejaronSeguir ?? 0)</span> seguidores
                    </div>
                </div>
            </div>
        </div>

        @if (_d.AlcanceSerie.Count > 1)
        {
            <div class="market-card mb-3">
                <div class="fw-semibold mb-2">Alcance de Instagram por día</div>
                <svg viewBox="0 0 640 140" preserveAspectRatio="none" style="width:100%;height:140px">
                    <polygon points="@($"0,130 {LineaPuntos(640, 130)} 640,130")" fill="#0F6E56" fill-opacity="0.12" stroke="none" />
                    <polyline points="@LineaPuntos(640, 130)" fill="none" stroke="#0F6E56" stroke-width="2" />
                </svg>
                <div class="d-flex justify-content-between small text-muted">
                    <span>@_d.AlcanceSerie.First().Fecha.ToString("dd/MM")</span>
                    <span>@_d.AlcanceSerie.Last().Fecha.ToString("dd/MM")</span>
                </div>
            </div>
        }

        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <h6 class="mb-0 fw-semibold">Contenido</h6>
            <div class="btn-group btn-group-sm ms-auto" role="group">
                <button class="btn @(_vista == "destacadas" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => Cambiar("destacadas")'>Destacadas</button>
                <button class="btn @(_vista == "ultimas" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => Cambiar("ultimas")'>Últimas</button>
            </div>
        </div>
        <div class="text-muted small mb-2">@(_vista == "destacadas" ? "Las de mayor alcance del período." : "Las publicaciones más recientes.")</div>

        @if (_cargandoUltimas)
        {
            <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
        }
        else if (Contenido.Count == 0)
        {
            <p class="text-muted">Sin publicaciones.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var p in Contenido)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="market-card mk-post h-100">
                            <div class="mk-post-img">
                                <img src="@($"api/marketing/thumb/{p.Red}/{Uri.EscapeDataString(p.PostId)}")" loading="lazy" alt=""
                                     onerror="this.closest('.mk-post-img').classList.add('mk-post-noimg')" />
                                <span class="mk-post-red @(p.Red == "IG" ? "ig" : "fb")">
                                    <i class="@(p.Red == "IG" ? "fa-brands fa-instagram" : "fa-brands fa-facebook")"></i>
                                </span>
                                @if (p.Pagada) { <span class="mk-post-pauta">Pauta</span> }
                            </div>
                            <div class="mk-post-body">
                                <div class="small text-muted">@(p.FechaPublicacion?.ToString("dd/MM/yyyy") ?? "")</div>
                                <div class="mk-post-txt">@(string.IsNullOrWhiteSpace(p.Texto) ? "(sin texto)" : p.Texto)</div>
                                <div class="mk-post-stats">
                                    <span title="Alcance"><i class="fa-solid fa-eye"></i> @Abrev(p.Alcance)</span>
                                    <span title="Me gusta"><i class="fa-solid fa-heart"></i> @Abrev(p.MeGusta)</span>
                                    <span title="Comentarios"><i class="fa-solid fa-comment"></i> @Abrev(p.Comentarios)</span>
                                    @if (!string.IsNullOrEmpty(p.Permalink))
                                    {
                                        <a class="ms-auto" href="@p.Permalink" target="_blank" rel="noopener" title="Abrir"><i class="fa-solid fa-up-right-from-square"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<style>
    .mk-kpi { display:flex; flex-direction:column; gap:2px; }
    .mk-kpi-head { display:flex; align-items:center; gap:8px; }
    .mk-kpi-ico { width:30px; height:30px; border-radius:9px; display:inline-flex; align-items:center; justify-content:center; color:#fff; font-size:.9rem; }
    .mk-kpi-label { font-size:.82rem; color:var(--bs-secondary-color,#6c757d); font-weight:500; }
    .mk-kpi-val { font-size:1.7rem; font-weight:700; line-height:1.1; margin-top:4px; }
    .mk-kpi-sub { font-size:.78rem; color:var(--bs-secondary-color,#6c757d); }
    .mk-post { padding:0 !important; overflow:hidden; display:flex; flex-direction:column; }
    .mk-post-img { position:relative; aspect-ratio:1/1; background:var(--mk-row-hover,rgba(128,128,128,.12)); }
    .mk-post-img img { width:100%; height:100%; object-fit:cover; display:block; }
    .mk-post-noimg img { display:none; }
    .mk-post-red { position:absolute; top:8px; left:8px; width:26px; height:26px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; color:#fff; font-size:.85rem; }
    .mk-post-red.ig { background:#E1306C; } .mk-post-red.fb { background:#1877F2; }
    .mk-post-pauta { position:absolute; top:8px; right:8px; background:var(--bs-success,#198754); color:#fff; font-size:.68rem; font-weight:600; padding:1px 7px; border-radius:999px; }
    .mk-post-body { padding:10px 12px; display:flex; flex-direction:column; gap:4px; flex:1; }
    .mk-post-txt { font-size:.82rem; line-height:1.35; flex:1; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .mk-post-stats { display:flex; align-items:center; gap:12px; font-size:.78rem; color:var(--bs-secondary-color,#6c757d); border-top:1px solid var(--bs-border-color,#e9ecef); padding-top:6px; }
    .mk-post-stats a { color:inherit; }
</style>

@code {
    private MktDashboardDto? _d;
    private bool _cargando = true, _cargandoUltimas;
    private string _vista = "destacadas";
    private List<MktPublicacionDto> _ultimas = new();

    private List<MktPublicacionDto> Contenido => _vista == "ultimas" ? _ultimas : (_d?.Destacados ?? new());

    protected override async Task OnInitializedAsync()
    {
        try { _d = await Api.DashboardAsync(); }
        catch { _d = null; }
        finally { _cargando = false; }
    }

    private async Task Cambiar(string vista)
    {
        _vista = vista;
        if (vista == "ultimas" && _ultimas.Count == 0)
        {
            _cargandoUltimas = true;
            try { _ultimas = await Api.PublicacionesAsync(top: 8); }
            catch { _ultimas = new(); }
            finally { _cargandoUltimas = false; }
        }
    }

    // Flecha de % vs período anterior.
    private static (double Pct, bool Up)? Delta(int? cur, int? prev)
    {
        if (cur is null || prev is null || prev.Value == 0) return null;
        var p = (cur.Value - prev.Value) / (double)prev.Value * 100;
        return (Math.Abs(p), p >= 0);
    }
    private MarkupString Flecha(int? cur, int? prev)
    {
        var d = Delta(cur, prev);
        if (d is null) return (MarkupString)"";
        var cls = d.Value.Up ? "text-success" : "text-danger";
        var ico = d.Value.Up ? "fa-arrow-up" : "fa-arrow-down";
        var txt = d.Value.Pct.ToString("0.0").Replace(".", ",");
        return (MarkupString)$"<span class='small {cls} ms-2' style='font-weight:600'><i class='fa-solid {ico}'></i> {txt}%</span>";
    }

    // Número grande abreviado: 2.830.108 -> "2,8 mill" · 75.597 -> "75,6 mil".
    private static string Abrev(int? n)
    {
        if (n is null) return "—";
        var v = n.Value;
        if (v >= 1_000_000) return (v / 1_000_000d).ToString("0.0").Replace(".", ",") + " mill";
        if (v >= 1_000) return (v / 1_000d).ToString("0.0").Replace(".", ",") + " mil";
        return v.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    }

    // Puntos de la polilínea del gráfico de alcance (escala al viewBox w×h).
    private string LineaPuntos(int w, int h)
    {
        var s = _d!.AlcanceSerie;
        long min = s.Min(p => p.Valor), max = s.Max(p => p.Valor);
        double rango = Math.Max(1, max - min);
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < s.Count; i++)
        {
            double x = s.Count == 1 ? 0 : (double)i / (s.Count - 1) * w;
            double y = h - (s[i].Valor - min) / rango * (h - 6) - 3;
            // Coordenadas como ENTEROS: si uso decimales, la cultura es-AR mete coma y rompe el "x,y" del SVG.
            sb.Append((int)Math.Round(x)).Append(',').Append((int)Math.Round(y)).Append(' ');
        }
        return sb.ToString().Trim();
    }
}
