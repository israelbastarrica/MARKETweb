@page "/marketing"
@using MarketWeb.Shared.Marketing
@inject MarketingApi Api

<PageTitle>Marketing — Redes</PageTitle>

<div class="market-page">
    <PageHeader Modulo="Marketing" Titulo="Redes Sociales" Icono="fa-solid fa-bullhorn" Compartible="false" />
    <p class="text-muted market-hint" style="margin-top:-.6rem">
        Publicaciones y métricas de Facebook e Instagram (Meta), que recolecta el agente de Marketing.
    </p>

    <div class="row g-3 mb-3">
        @foreach (var p in _perfiles)
        {
            <div class="col-6 col-md-3">
                <div class="market-card">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="@(p.Red == "IG" ? "fa-brands fa-instagram text-danger" : "fa-brands fa-facebook text-primary")"></i>
                        <span class="fw-semibold">@(p.Red == "IG" ? "Instagram" : "Facebook")</span>
                    </div>
                    <div class="fs-3 fw-bold">@(p.Seguidores?.ToString("N0") ?? "—")</div>
                    <div class="small text-muted">seguidores · @(p.Publicaciones?.ToString("N0") ?? "—") publicaciones</div>
                    <div class="small text-muted">@(p.FechaHora?.ToString("dd/MM/yyyy HH:mm") ?? "")</div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
        <div>
            <label class="form-label small text-muted mb-1">Red</label>
            <select class="form-select" @bind="_red" @bind:after="Cargar">
                <option value="TODOS">Todas</option>
                <option value="IG">Instagram</option>
                <option value="FB">Facebook</option>
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Pauta</label>
            <select class="form-select" @bind="_pauta">
                <option value="TODAS">Todas</option>
                <option value="ORG">Orgánicas</option>
                <option value="PAGA">Pagadas</option>
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Mostrar</label>
            <select class="form-select" @bind="_top" @bind:after="Cargar">
                <option value="50">Últimas 50</option>
                <option value="100">Últimas 100</option>
                <option value="200">Últimas 200</option>
            </select>
        </div>
        <button class="btn btn-outline-secondary" @onclick="Cargar"><i class="fa-solid fa-rotate me-1"></i> Actualizar</button>
    </div>

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_posts.Count == 0)
    {
        <div class="market-empty">
            <i class="fa-solid fa-bullhorn"></i>
            <p>No hay publicaciones todavía.</p>
            <p class="small text-muted mb-0">Las tablas se llenan cuando corre el colector de redes (Meta).</p>
        </div>
    }
    else
    {
        <div class="market-card table-responsive">
            <table class="market-table align-middle">
                <thead>
                    <tr>
                        <th>Red</th><th>Tipo</th><th class="text-center">Pauta</th><th>Fecha</th><th>Texto</th>
                        <th class="text-end">Alcance</th><th class="text-end">Me gusta</th><th class="text-end">Coment.</th>
                        <th class="text-end">Comp.</th><th class="text-end">Guard.</th><th class="text-end">Reprod.</th>
                        <th class="text-end">Gasto</th><th class="text-center">Ver</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in PostsFiltrados)
                    {
                        <tr>
                            <td><i class="@(p.Red == "IG" ? "fa-brands fa-instagram text-danger" : "fa-brands fa-facebook text-primary")" title="@p.Red"></i></td>
                            <td class="small">@p.Tipo</td>
                            <td class="text-center">
                                @if (p.Pagada)
                                {
                                    <span class="badge text-bg-success" title="@($"{p.ImpresionesPago:N0} impresiones pagas · {p.ImpresionesOrganico:N0} orgánicas · gasto {p.MonedaAd} {p.Gasto:N0}")">Pagada</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border">Orgánica</span>
                                }
                            </td>
                            <td class="small text-nowrap">@(p.FechaPublicacion?.ToString("dd/MM/yy HH:mm") ?? "—")</td>
                            <td class="small" style="max-width:280px"><div class="text-truncate" title="@p.Texto">@p.Texto</div></td>
                            <td class="text-end">@(p.Alcance?.ToString("N0") ?? "—")</td>
                            <td class="text-end">@(p.MeGusta?.ToString("N0") ?? "—")</td>
                            <td class="text-end">@(p.Comentarios?.ToString("N0") ?? "—")</td>
                            <td class="text-end">@(p.Compartidos?.ToString("N0") ?? "—")</td>
                            <td class="text-end">@(p.Guardados?.ToString("N0") ?? "—")</td>
                            <td class="text-end">@(p.Reproducciones?.ToString("N0") ?? "—")</td>
                            <td class="text-end fw-semibold">@(p.Gasto.HasValue && p.Gasto > 0 ? $"{p.MonedaAd} {p.Gasto:N0}".Trim() : "—")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(p.Permalink))
                                {
                                    <a href="@p.Permalink" target="_blank" rel="noopener" title="Abrir publicación"><i class="fa-solid fa-up-right-from-square"></i></a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="small text-muted mt-2">@PostsFiltrados.Count de @_posts.Count publicaciones · métricas del último snapshot por post.</p>
    }
</div>

@code {
    private List<MktPerfilDto> _perfiles = new();
    private List<MktPublicacionDto> _posts = new();
    private string _red = "TODOS";
    private string _pauta = "TODAS";
    private int _top = 100;
    private bool _cargando = true;

    private List<MktPublicacionDto> PostsFiltrados => _pauta switch
    {
        "PAGA" => _posts.Where(p => p.Pagada).ToList(),
        "ORG" => _posts.Where(p => !p.Pagada).ToList(),
        _ => _posts
    };

    protected override async Task OnInitializedAsync()
    {
        try { _perfiles = await Api.PerfilesAsync(); } catch { _perfiles = new(); }
        await Cargar();
    }

    private async Task Cargar()
    {
        _cargando = true;
        try { _posts = await Api.PublicacionesAsync(_red, _top); }
        catch { _posts = new(); }
        finally { _cargando = false; }
    }
}
