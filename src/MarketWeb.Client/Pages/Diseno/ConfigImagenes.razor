@page "/diseno/config-imagenes"
@implements IAsyncDisposable
@inject ConfigImagenesApi Api
@inject IJSRuntime JS

<PageTitle>Config Imágenes</PageTitle>

<div class="market-page">
    <PageHeader Modulo="Diseño" Titulo="Config Imágenes" Icono="fa-solid fa-image-portrait" />

    @* Filtros (espejo de gpbDatos: Descripción + Tipo + Procesar) *@
    <div class="market-card p-3 mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-5">
                <label class="form-label">Descripción</label>
                <input class="form-control" placeholder="Buscar por descripción..."
                       @bind="_descripcion" @bind:event="oninput" @onkeyup="OnKeyUp" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Tipo</label>
                <select class="form-select" @bind="_tipo">
                    <option value="TODOS">TODOS</option>
                    @foreach (var t in TiposConfigImagen.Todos)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <button class="btn btn-outline-secondary w-100" @onclick="Procesar">
                    <i class="fa-solid fa-magnifying-glass me-1"></i> Procesar
                </button>
            </div>
        </div>
    </div>

    @* Barra de acciones (espejo de pnlBotones: Agregar / Modificar / Eliminar) *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-primary" @onclick="AbrirAlta">
            <i class="fa-solid fa-plus me-1"></i> Agregar
        </button>
        <button class="btn btn-outline-primary" disabled="@(_seleccionado is null)"
                @onclick="() => AbrirModificacion(_seleccionado!)">
            <i class="fa-solid fa-pen me-1"></i> Modificar
        </button>
        <button class="btn btn-outline-danger" disabled="@(_seleccionado is null)" @onclick="EliminarSeleccionado">
            <i class="fa-solid fa-trash me-1"></i> Eliminar
        </button>
        <span class="align-self-center text-muted small ci-hint">
            <i class="fa-solid fa-arrow-pointer me-1"></i>Tip: arrastrá una imagen a la pantalla para darla de alta.
        </span>
        <span class="ms-auto align-self-center text-muted small">
            @_items.Count imagen(es)@(_seleccionado is null ? "" : $" · seleccionada: {_seleccionado.Descripcion}")
        </span>
    </div>

    @* Drag & drop invisible a nivel ventana (configImagenesDrop.js): se puede soltar la imagen
       en cualquier parte de la galería. Este overlay aparece SOLO mientras arrastrás. *@
    @if (_drag)
    {
        <div class="ci-dropoverlay">
            <div class="ci-dropoverlay-box">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                <span>Soltá la imagen para dar de alta</span>
            </div>
        </div>
    }

    @if (_mensaje is not null)
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @_mensaje
            <button type="button" class="btn-close" @onclick="() => _mensaje = null"></button>
        </div>
    }
    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Cargar">Reintentar</button>
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_items.Count == 0)
    {
        <div class="market-empty">
            <i class="fa-solid fa-image"></i>
            <p>No se encontraron imágenes con esos filtros.</p>
        </div>
    }
    else
    {
        <div class="ci-grid">
            @foreach (var it in _items)
            {
                <div class="ci-card @(_seleccionado?.Id == it.Id ? "sel" : "")"
                     @onclick="() => Seleccionar(it)" @ondblclick="() => AbrirModificacion(it)"
                     title="Doble clic para modificar">
                    <div class="ci-thumb">
                        @if (it.TieneImagen)
                        {
                            <img src="@ConfigImagenesApi.ImagenUrl(it.Id, _cacheBust)" alt="@it.Descripcion" loading="lazy" />
                        }
                        else
                        {
                            <div class="ci-noimg"><i class="fa-solid fa-image"></i></div>
                        }
                    </div>
                    <div class="ci-body">
                        <span class="badge text-bg-secondary ci-tipo">@it.Tipo</span>
                        <div class="ci-desc" title="@it.Descripcion">@it.Descripcion</div>
                        @if (!string.IsNullOrWhiteSpace(it.MatchArticulo))
                        {
                            <div class="ci-match" title="Match Artículo">
                                <i class="fa-solid fa-key me-1"></i>@it.MatchArticulo
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_modalAbierto)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <EditForm Model="_editado" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />
                    <div class="modal-header">
                        <h5 class="modal-title">@(_esAlta ? "Nueva imagen" : "Modificar imagen")</h5>
                        <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                    </div>
                    <div class="modal-body">
                        @if (_errorModal is not null)
                        {
                            <div class="alert alert-danger py-2">@_errorModal</div>
                        }
                        <div class="row g-3">
                            <div class="col-12 col-md-7">
                                <div class="mb-3">
                                    <label class="form-label">Tipo</label>
                                    <InputSelect class="form-select" @bind-Value="_editado.Tipo">
                                        <option value="">— Seleccione —</option>
                                        @foreach (var t in TiposConfigImagen.Todos)
                                        {
                                            <option value="@t">@t</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => _editado.Tipo" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Descripción</label>
                                    <InputText class="form-control" @bind-Value="_editado.Descripcion" />
                                    <ValidationMessage For="() => _editado.Descripcion" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label">Match Artículo</label>
                                    <InputText class="form-control" @bind-Value="_editado.MatchArticulo"
                                               placeholder="REM,SW,CARD" />
                                    <div class="form-text">
                                        Palabras clave separadas por coma. Obligatorio para
                                        <b>ETIQUETAS PRENDAS</b> (define qué etiqueta se asigna a cada artículo).
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-5">
                                <label class="form-label">Imagen</label>
                                <div class="ci-preview mb-2">
                                    @if (PreviewSrc is not null)
                                    {
                                        <img src="@PreviewSrc" alt="preview" />
                                    }
                                    else
                                    {
                                        <div class="ci-noimg"><i class="fa-solid fa-image"></i><span>Sin imagen</span></div>
                                    }
                                </div>
                                <InputFile class="form-control" OnChange="OnArchivo" accept="image/*" />
                                @if (PreviewSrc is not null)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2" @onclick="VerImagen">
                                        <i class="fa-solid fa-eye me-1"></i> Ver
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@_guardando">
                            @if (_guardando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> }
                            Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private const long MaxImagen = 10 * 1024 * 1024; // 10 MB

    private readonly List<ConfigImagenDto> _items = new();
    private string _tipo = "TODOS";
    private string _descripcion = "";
    private bool _cargando = true;
    private string? _mensaje;
    private string? _error;
    private int _cacheBust;

    private ConfigImagenDto? _seleccionado;

    // Estado del modal ABM
    private bool _modalAbierto;
    private bool _esAlta;
    private bool _guardando;
    private int _idEditado;
    private string? _errorModal;
    private ConfigImagenSaveRequest _editado = new();
    private string? _previewData;        // data:...;base64 de una imagen recién elegida
    private bool _tieneImagenActual;     // en modificación, ya hay imagen guardada
    private bool _drag;                  // hover visual del dropzone

    // Qué mostrar en el preview del modal: la nueva elegida o la guardada.
    private string? PreviewSrc =>
        _previewData
        ?? (!_esAlta && _tieneImagenActual ? ConfigImagenesApi.ImagenUrl(_idEditado, _cacheBust) : null);

    protected override async Task OnInitializedAsync() => await Cargar();

    private Task Procesar() => Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _error = null;
        try
        {
            var datos = await Api.ListarAsync(_tipo, _descripcion);
            _items.Clear();
            _items.AddRange(datos);
            // Si el seleccionado ya no está en la lista, lo soltamos.
            if (_seleccionado is not null && !_items.Any(x => x.Id == _seleccionado.Id))
                _seleccionado = null;
        }
        catch (Exception ex)
        {
            _items.Clear();
            _seleccionado = null;
            _error = "No se pudieron cargar las imágenes. Verificá la conexión a la base de datos.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Cargar();
    }

    private void Seleccionar(ConfigImagenDto it)
        => _seleccionado = _seleccionado?.Id == it.Id ? null : it;

    private void AbrirAlta()
    {
        _esAlta = true;
        _idEditado = 0;
        _editado = new ConfigImagenSaveRequest();
        _tieneImagenActual = false;
        _previewData = null;
        _errorModal = null;
        _modalAbierto = true;
    }

    private void AbrirModificacion(ConfigImagenDto it)
    {
        _esAlta = false;
        _seleccionado = it;
        _idEditado = it.Id;
        _editado = new ConfigImagenSaveRequest
        {
            Tipo = it.Tipo,
            Descripcion = it.Descripcion,
            MatchArticulo = it.MatchArticulo,
        };
        _tieneImagenActual = it.TieneImagen;
        _previewData = null;
        _errorModal = null;
        _modalAbierto = true;
    }

    private void CerrarModal() => _modalAbierto = false;

    // InputFile dentro del modal (botón Seleccionar archivo).
    private async Task OnArchivo(InputFileChangeEventArgs e)
    {
        if (e.File is not null) await CargarArchivoAsync(e.File);
    }

    // ---- Drag & drop invisible a nivel ventana (configImagenesDrop.js) ----
    private IJSObjectReference? _dropModule;
    private DotNetObjectReference<ConfigImagenes>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _selfRef = DotNetObjectReference.Create(this);
        _dropModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/configImagenesDrop.js");
        await _dropModule.InvokeVoidAsync("init", _selfRef);
    }

    // JS avisa cuando entra/sale un archivo arrastrado: solo prende/apaga el overlay.
    [JSInvokable]
    public Task SetDragActivo(bool activo)
    {
        _drag = activo;
        return InvokeAsync(StateHasChanged);
    }

    // JS al soltar una imagen: abre el alta con la foto ya cargada (espejo del DragDrop del desktop).
    // Si el modal ya está abierto, reemplaza la imagen del registro en edición.
    [JSInvokable]
    public async Task RecibirImagenArrastrada(string nombre, string contentType, string b64)
    {
        _drag = false;
        if (!EsImagenTipo(contentType, nombre))
        {
            _error = "Tenés que soltar un archivo de imagen (JPG, PNG, etc.).";
            await InvokeAsync(StateHasChanged);
            return;
        }
        if (!_modalAbierto) AbrirAlta();
        _editado.ImagenBase64 = b64;
        var ct = string.IsNullOrWhiteSpace(contentType) ? "image/png" : contentType;
        _previewData = $"data:{ct};base64,{b64}";
        _errorModal = null;
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task RecibirErrorArrastre(string mensaje)
    {
        _drag = false;
        _error = mensaje;
        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_dropModule is not null)
            {
                await _dropModule.InvokeVoidAsync("dispose");
                await _dropModule.DisposeAsync();
            }
        }
        catch { /* el circuito puede estar cerrándose */ }
        _selfRef?.Dispose();
    }

    private async Task CargarArchivoAsync(IBrowserFile file)
    {
        if (!EsImagen(file))
        {
            _errorModal = "Tenés que soltar o elegir un archivo de imagen (JPG, PNG, etc.).";
            return;
        }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxImagen).CopyToAsync(ms);
            var bytes = ms.ToArray();
            var b64 = Convert.ToBase64String(bytes);
            _editado.ImagenBase64 = b64;
            var ct = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType;
            _previewData = $"data:{ct};base64,{b64}";
            _errorModal = null;
        }
        catch (IOException)
        {
            _errorModal = "La imagen supera el tamaño máximo permitido (10 MB).";
        }
        catch (Exception ex)
        {
            _errorModal = "No se pudo leer la imagen.";
            Console.Error.WriteLine(ex);
        }
    }

    private static bool EsImagen(IBrowserFile f) => EsImagenTipo(f.ContentType, f.Name);

    private static bool EsImagenTipo(string? contentType, string? nombre)
    {
        if (!string.IsNullOrEmpty(contentType) && contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            return true;
        var ext = Path.GetExtension(nombre ?? "").ToLowerInvariant();
        return ext is ".jpg" or ".jpeg" or ".png" or ".bmp" or ".gif" or ".webp";
    }

    private async Task Guardar()
    {
        _guardando = true;
        _errorModal = null;

        var (ok, error) = _esAlta
            ? await Api.CrearAsync(_editado)
            : await Api.ModificarAsync(_idEditado, _editado);

        _guardando = false;
        if (!ok)
        {
            _errorModal = error;
            return;
        }

        _modalAbierto = false;
        _cacheBust++; // fuerza recarga de las imágenes (la modificada cambió)
        _mensaje = _esAlta ? "Registro agregado correctamente." : "Registro modificado correctamente.";
        await Cargar();
    }

    private async Task EliminarSeleccionado()
    {
        if (_seleccionado is null) return;
        var confirma = await JS.InvokeAsync<bool>("confirm",
            $"¿Está seguro que desea eliminar \"{_seleccionado.Descripcion}\" del catálogo?");
        if (!confirma) return;

        await Api.EliminarAsync(_seleccionado.Id);
        _seleccionado = null;
        _mensaje = "Registro eliminado correctamente.";
        await Cargar();
    }

    private async Task VerImagen()
    {
        if (PreviewSrc is null) return;
        try { await JS.InvokeVoidAsync("open", PreviewSrc, "_blank"); } catch { }
    }
}
