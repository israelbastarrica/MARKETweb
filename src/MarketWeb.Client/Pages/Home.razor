@page "/"
@inject UsoApi Uso

<PageTitle>MARKET Web</PageTitle>

<div class="market-page">
    <div class="home-hero">
        <div class="home-brand">MARKET <span>WEB</span></div>
        <div class="home-greet">@Saludo@(string.IsNullOrEmpty(_nombre) ? "" : ", ")<strong>@_nombre</strong></div>
        <div class="home-meta">
            @if (!string.IsNullOrEmpty(_perfil)) { <span class="home-badge">@_perfil</span> }
            <span class="home-fecha">@Fecha</span>
        </div>
    </div>

    @if (_tiles.Length > 0)
    {
        <h2 class="home-sec">@(_personalizado ? "Tus accesos más usados" : "Accesos rápidos")</h2>
        <div class="home-tiles">
            @foreach (var t in _tiles)
            {
                <a class="home-tile" href="@t.Ruta">
                    <i class="@t.Icono"></i>
                    <span>@t.Etiqueta</span>
                </a>
            }
        </div>
    }
    else
    {
        <p class="text-muted home-vacio">Elegí un módulo del menú para empezar.</p>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _nombre = "";
    private string _perfil = "";
    private Acceso[] _tiles = Array.Empty<Acceso>();
    private bool _personalizado;   // hay historial propio (no solo sugeridos por perfil)

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            _nombre = PrimerNombre(user.Identity?.Name);
            _perfil = user.FindFirst("perfil")?.Value ?? "";
        }
        await ArmarAccesos();
    }

    private async Task ArmarAccesos()
    {
        var orden = new List<string>();

        // 1) Lo más usado por el usuario (estadística real).
        var top = await Uso.TopAsync(8);
        foreach (var r in top)
            if (Accesos.PorRuta(r) is not null && !orden.Contains(r)) orden.Add(r);

        _personalizado = orden.Count > 0;

        // 2) Completar con sugeridos por perfil (para usuarios nuevos / pocas visitas).
        foreach (var r in SugeridosPorPerfil(_perfil))
            if (!orden.Contains(r)) orden.Add(r);

        _tiles = orden.Take(6).Select(r => Accesos.PorRuta(r)!).Where(a => a is not null).ToArray();
    }

    private string Saludo => DateTime.Now.Hour switch
    {
        >= 6 and < 13 => "Buen día",
        >= 13 and < 20 => "Buenas tardes",
        _ => "Buenas noches"
    };

    private static readonly string[] _dias = { "domingo", "lunes", "martes", "miércoles", "jueves", "viernes", "sábado" };
    private static readonly string[] _meses = { "enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre" };

    private static string Fecha
    {
        get
        {
            var d = DateTime.Now;
            var s = $"{_dias[(int)d.DayOfWeek]} {d.Day} de {_meses[d.Month - 1]}";
            return char.ToUpperInvariant(s[0]) + s[1..];
        }
    }

    private static string PrimerNombre(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "";
        var n = nombre.Contains('@') ? nombre.Split('@')[0] : nombre;
        var p = n.Split(new[] { ' ', '.' }, StringSplitOptions.RemoveEmptyEntries);
        if (p.Length == 0) return "";
        var w = p[0];
        return char.ToUpperInvariant(w[0]) + (w.Length > 1 ? w[1..].ToLowerInvariant() : "");
    }

    // Sugeridos por perfil (rutas canónicas). Se usan para completar cuando no hay
    // historial suficiente. El menú sigue teniendo todo.
    private static string[] SugeridosPorPerfil(string perfil) => perfil.ToUpperInvariant() switch
    {
        "ADMIN" => new[] { "/locales/dashboard", "/administracion/insumos", "/configuracion/usuarios", "/compras/calculadora" },
        "LURO" or "PERALTA" => new[] { "/locales/dashboard", "/insumos/pedidos", "/consulta-articulo", "/locales/despachos" },
        "LOGISTICA" => new[] { "/logistica/dashboard", "/logistica/palets", "/logistica/despachos", "/logistica/remito-impresion" },
        "COMPRAS" => new[] { "/compras/calculadora" },
        _ => Array.Empty<string>()
    };
}
