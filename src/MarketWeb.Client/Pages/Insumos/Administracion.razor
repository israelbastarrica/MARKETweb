@page "/administracion/insumos"
@implements IDisposable
@inject InsumosApi Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject PageStateService State

<PageTitle>Insumos · Administración</PageTitle>

<div class="market-page">
    <div class="no-print">
        <PageHeader Modulo="Administración" Titulo="Insumos" Icono="fa-solid fa-boxes-stacked" />
    </div>

    <p class="text-muted no-print market-hint" style="margin-top:-.6rem">
        Consumos consolidados por <strong>proveedor</strong> (registros + pedidos enviados).
    </p>

    <div class="d-flex flex-wrap gap-2 align-items-end mb-3 no-print">
        <div>
            <label class="form-label small text-muted mb-1">Ubicación</label>
            <select class="form-select" style="min-width: 220px" @bind="_ubicacionSel" @bind:after="Cargar">
                <option value="0">TODOS</option>
                <option value="-1">LOCALES</option>
                @foreach (var u in _ubicaciones)
                {
                    <option value="@u.Id">@u.Descripcion</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Estado</label>
            <select class="form-select" style="min-width: 160px" @bind="_estado" @bind:after="Cargar">
                <option value="SIN MARCAR">SIN MARCAR</option>
                <option value="MARCADOS">MARCADOS</option>
                <option value="TODOS">TODOS</option>
            </select>
        </div>
        <button class="btn btn-outline-secondary" @onclick="Cargar">
            <i class="fa-solid fa-rotate me-1"></i> Actualizar
        </button>
        <button class="btn btn-outline-primary" @onclick="Imprimir" disabled="@(_consumos.Count == 0)">
            <i class="fa-solid fa-print me-1"></i> Imprimir
        </button>
        <button class="btn btn-success" @onclick="Marcar" disabled="@(_sel.Count == 0)">
            <i class="fa-solid fa-check me-1"></i> Marcar@(_sel.Count > 0 ? $" ({_sel.Count})" : "")
        </button>
    </div>

    @if (_flash is not null)
    {
        <div class="alert alert-success d-flex align-items-center no-print" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>
            <div class="flex-grow-1">@_flash</div>
            <button class="btn-close" @onclick="() => _flash = null"></button>
        </div>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Cargar">Reintentar</button>
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_consumos.Count == 0)
    {
        <div class="market-empty">
            <i class="fa-solid fa-box-open"></i>
            <p>No se encontraron consumos.</p>
        </div>
    }
    else
    {
        <div class="solo-print market-print-head">
            <h2>Insumos · Consumos por proveedor</h2>
            <p>Ubicación: <strong>@UbicacionLabel()</strong> · Estado: <strong>@_estado</strong> · @_consumos.Count consumo(s) · Impreso @_impreso.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div class="market-card table-responsive">
            <table class="market-table align-middle">
                <thead>
                    <tr>
                        <th class="no-print text-center" style="width: 44px">Sel.</th>
                        <th style="width: 18%">Ubicación</th>
                        <th style="width: 16%">Cód. Art</th>
                        <th>Descripción</th>
                        <th class="text-end" style="width: 110px">Cant. Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in _consumos.GroupBy(c => c.Proveedor))
                    {
                        <tr class="fila-proveedor">
                            <td class="no-print text-center">
                                <input type="checkbox" class="form-check-input" checked="@ProvSel(g)"
                                       @onchange="e => ToggleProv(g, (bool)(e.Value ?? false))" />
                            </td>
                            <td colspan="4"><i class="fa-solid fa-truck-field me-2"></i>@g.Key</td>
                        </tr>
                        @foreach (var c in g)
                        {
                            <tr class="@(RowSel(c) ? "table-active" : null)">
                                <td class="no-print text-center">
                                    <input type="checkbox" class="form-check-input" checked="@RowSel(c)"
                                           @onchange="e => ToggleRow(c, (bool)(e.Value ?? false))" />
                                </td>
                                <td>@c.Ubicacion</td>
                                <td>@c.ArtCod</td>
                                <td>@c.Descripcion</td>
                                <td class="text-end">@Fmt.Miles(c.CantidadTotal)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small no-print">@_consumos.Count consumo(s).</p>
    }
</div>

@code {
    private List<UbicacionDto> _ubicaciones = new();
    private List<InsumoConsumoDto> _consumos = new();
    private int _ubicacionSel = 0;
    private string _estado = "SIN MARCAR";
    private bool _cargando = true;
    private string? _error;
    private DateTime _impreso = DateTime.Now;

    private string UbicacionLabel() => _ubicacionSel switch
    {
        0 => "TODOS",
        -1 => "LOCALES",
        _ => _ubicaciones.FirstOrDefault(u => u.Id == _ubicacionSel)?.Descripcion ?? "—"
    };

    private async Task Imprimir()
    {
        _impreso = DateTime.Now;
        StateHasChanged();
        await Task.Delay(80);          // dejar que el encabezado solo-print se renderice
        try { await JS.InvokeVoidAsync("print"); } catch { }
    }

    // ---- Selección + Marcar ----
    private readonly HashSet<string> _sel = new();   // claves = AgrupacionIds de las filas tildadas
    private string? _flash;

    private bool RowSel(InsumoConsumoDto c) => c.AgrupacionIds is not null && _sel.Contains(c.AgrupacionIds);

    private void ToggleRow(InsumoConsumoDto c, bool val)
    {
        if (c.AgrupacionIds is null) return;
        if (val) _sel.Add(c.AgrupacionIds); else _sel.Remove(c.AgrupacionIds);
    }

    private bool ProvSel(IGrouping<string, InsumoConsumoDto> g)
        => g.All(c => c.AgrupacionIds is not null && _sel.Contains(c.AgrupacionIds));

    private void ToggleProv(IGrouping<string, InsumoConsumoDto> g, bool val)
    {
        foreach (var c in g) ToggleRow(c, val);
    }

    private async Task Marcar()
    {
        if (_sel.Count == 0) return;
        var seleccionados = _sel.Count;
        var ok = await JS.InvokeAsync<bool>("confirm",
            $"¿Marcar {seleccionados} consumo(s) como procesados? Pasarán al historial de procesados.");
        if (!ok) return;

        var refs = _sel.SelectMany(k => k.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                       .Distinct().ToList();
        try
        {
            var n = await Api.MarcarAsync(refs);
            _sel.Clear();
            _flash = $"Se marcaron {n} consumo(s) como procesados.";
            await Cargar();   // recarga → los marcados desaparecen del filtro SIN MARCAR
        }
        catch (Exception ex)
        {
            _error = "No se pudieron marcar los consumos. Verificá la conexión.";
            Console.Error.WriteLine(ex);
        }
    }

    private IDisposable? _navReg;
    private bool _restaurarScroll;
    private double _scroll;
    private const string EstadoKey = "insumos-admin";

    private sealed record EstadoInsumos(int UbicacionSel, string Estado, List<InsumoConsumoDto> Consumos);

    protected override async Task OnInitializedAsync()
    {
        _navReg = Nav.RegisterLocationChangingHandler(OnNavegandoAfuera);

        try { _ubicaciones = await Api.ListarUbicacionesAsync(); }
        catch { _ubicaciones = new(); }

        if (State.TryGet<EstadoInsumos>(EstadoKey, out var st, out _scroll))
        {
            _ubicacionSel = st.UbicacionSel; _estado = st.Estado; _consumos = st.Consumos;
            _cargando = false;
            _restaurarScroll = true;
            return;
        }

        await Cargar();
    }

    private async ValueTask OnNavegandoAfuera(Microsoft.AspNetCore.Components.Routing.LocationChangingContext ctx)
    {
        double y = 0;
        try { y = await JS.InvokeAsync<double>("scrollGet"); } catch { }
        State.Save(EstadoKey, new EstadoInsumos(_ubicacionSel, _estado, _consumos), y);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_restaurarScroll)
        {
            _restaurarScroll = false;
            try { await JS.InvokeVoidAsync("scrollSet", _scroll); } catch { }
        }
    }

    public void Dispose() => _navReg?.Dispose();

    private async Task Cargar()
    {
        _cargando = true;
        _error = null;
        _sel.Clear();
        try
        {
            int? ubic = _ubicacionSel == 0 ? null : _ubicacionSel;
            _consumos = await Api.ListarConsumosAsync(ubic, _estado);
        }
        catch (Exception ex)
        {
            _consumos = new();
            _error = "No se pudieron cargar los consumos. Verificá la conexión a la base de datos.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _cargando = false;
        }
    }
}
