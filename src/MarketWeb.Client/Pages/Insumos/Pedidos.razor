@page "/insumos/pedidos"
@inject InsumosApi Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject UiService Ui

<PageTitle>Insumos · Pedidos</PageTitle>

<div class="market-page">
    <div class="no-print">
    <PageHeader Modulo="Insumos" Titulo="Pedidos" Icono="fa-solid fa-boxes-stacked" CompartirQuery="@CompartirQuery" />

    <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
        <div>
            <label class="form-label small text-muted mb-1">Ubicación</label>
            <select class="form-select" style="min-width: 220px" @bind="_ubicacionSel" @bind:after="Cargar" disabled="@_ubicacionFija">
                <option value="0">TODOS</option>
                <option value="-1">LOCALES</option>
                @foreach (var u in _ubicaciones)
                {
                    <option value="@u.Id">@u.Descripcion</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label small text-muted mb-1">Estado</label>
            <select class="form-select" style="min-width: 160px" @bind="_estado" @bind:after="Cargar">
                <option value="SIN ENVIAR">SIN ENVIAR</option>
                <option value="ENVIADOS">ENVIADOS</option>
                <option value="TODOS">TODOS</option>
            </select>
        </div>
        <button class="btn btn-outline-secondary" @onclick="Cargar">
            <i class="fa-solid fa-rotate me-1"></i> Actualizar
        </button>
        @if (_esDeposito)
        {
            <button class="btn btn-outline-primary" @onclick="ImprimirArmado" title="Imprimir hoja de ruta de armado (marca EN ARMADO)">
                <i class="fa-solid fa-print me-1"></i> Imprimir armado
            </button>
            <button class="btn btn-success" @onclick="GenerarRemitos" disabled="@_generando" title="Genera el remito de insumos de cada local en Dragonfish (Motivo 13) y marca los pedidos ENVIADOS">
                @if (_generando) { <i class="fa-solid fa-spinner fa-spin me-1"></i> } else { <i class="fa-solid fa-file-invoice me-1"></i> }
                Generar remitos
            </button>
        }
        @if (_puedeABM)
        {
            <button class="btn btn-primary" @onclick="NuevoPedido" title="Crear un pedido nuevo">
                <i class="fa-solid fa-plus me-1"></i> Nuevo pedido
            </button>
        }
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div class="flex-grow-1">@_error</div>
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Cargar">Reintentar</button>
        </div>
    }

    @if (_cargando)
    {
        <p class="text-muted"><i class="fa-solid fa-spinner fa-spin me-2"></i>Cargando...</p>
    }
    else if (_pedidos.Count == 0)
    {
        <div class="market-empty">
            <i class="fa-solid fa-box-open"></i>
            <p>No se encontraron pedidos de insumos.</p>
        </div>
    }
    else
    {
        <div class="market-card table-responsive">
            <table class="market-table align-middle">
                <thead>
                    <tr>
                        <th>Ubicación</th>
                        <th class="text-end" style="width: 110px">Nro. Pedido</th>
                        <th>Estado</th>
                        <th class="text-end" style="width: 80px">Art.</th>
                        <th class="text-end" style="width: 90px">Cantidad</th>
                        <th class="text-end" style="width: 90px">Art. Env.</th>
                        <th class="text-end" style="width: 100px">Cant. Env.</th>
                        @if (_puedeABM || _esDeposito)
                        {
                            <th class="text-center" style="width: 96px">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _pedidos)
                    {
                        <tr class="@(p.Enviado ? "fila-enviado" : null)">
                            <td>@p.Ubicacion</td>
                            <td class="text-end">@p.NroPedido</td>
                            <td>@p.Estado</td>
                            <td class="text-end">@Fmt.Miles(p.CantArt)</td>
                            <td class="text-end">@Fmt.Miles(p.CantidadTotal)</td>
                            <td class="text-end">@Fmt.Miles(p.CantArtEnviada)</td>
                            <td class="text-end">@Fmt.Miles(p.CantidadTotalEnviada)</td>
                            @if (_puedeABM || _esDeposito)
                            {
                                <td class="text-center acciones">
                                    <button class="btn btn-sm btn-outline-secondary" title="@(SoloLectura(p) ? "Ver" : "Abrir / Modificar")"
                                            @onclick="() => Abrir(p)">
                                        <i class="fa-solid @(SoloLectura(p) ? "fa-eye" : "fa-pen")"></i>
                                    </button>
                                    @if (_esDeposito && p.EnArmado)
                                    {
                                        <button class="btn btn-sm btn-success" disabled="@(!p.Procesado || _generando)"
                                                title="@(p.Procesado ? "Generar el remito de este pedido en Dragonfish" : "Guardá el pedido (acomodá según stock) antes de generar el remito")"
                                                @onclick="() => GenerarRemitoPedido(p)">
                                            <i class="fa-solid fa-file-invoice"></i>
                                        </button>
                                    }
                                    @if (_puedeABM && !p.Cerrado)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" title="Eliminar" @onclick="() => Eliminar(p)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">@_pedidos.Count pedido(s).</p>
    }
    </div>

    @* Hoja de ruta de armado: solo se ve al imprimir (clase solo-print global). *@
    @if (_armado is not null)
    {
        <div class="solo-print">
            @foreach (var p in _armado.Pedidos)
            {
                <div class="armado-pedido">
                    <h3>ARMADO DE INSUMOS</h3>
                    <div class="armado-sub">Local: <strong>@p.Local</strong> · Pedido N° <strong>@p.NroPedido</strong> · @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
                    <table class="armado-tabla">
                        <thead><tr><th>Código</th><th>Descripción</th><th class="r">Cant.</th></tr></thead>
                        <tbody>
                            @foreach (var r in p.Renglones)
                            {
                                <tr><td>@r.ArtCod</td><td>@r.Descripcion</td><td class="r">@r.Cantidad</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>

<style>
    .armado-pedido { break-inside: avoid; padding-bottom: 10px; margin-bottom: 14px; border-bottom: 2px solid #000; }
    .armado-sub { font-size: 9pt; margin-bottom: 8px; }
    .solo-print h3 { font-size: 14pt; margin: 0 0 4px; }
    .armado-tabla { width: 100%; border-collapse: collapse; font-size: 9pt; }
    .armado-tabla th, .armado-tabla td { border-bottom: 1px solid #999; padding: 3px 6px; text-align: left; }
    .armado-tabla th.r, .armado-tabla td.r { text-align: right; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<UbicacionDto> _ubicaciones = new();
    private List<PedidoInsumoDto> _pedidos = new();
    private int _ubicacionSel = 0;
    private string _estado = "SIN ENVIAR";
    private bool _cargando = true;
    private string? _error;

    private string _perfil = "";
    private bool _puedeABM;          // LURO/PERALTA/ADMIN pueden ABM
    private bool _esDeposito;        // LOGISTICA/ADMIN: pueden imprimir el armado
    private bool _ubicacionFija;     // local con ubicación bloqueada
    private int _idLocalPedir;       // local con el que se crea un pedido (2/3)
    private ArmadoInsumosDto? _armado;   // hoja de ruta para imprimir

    // Deep-link / Compartir: filtros en la URL.
    [Parameter, SupplyParameterFromQuery(Name = "ubic")] public int? UbicQ { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "estado")] public string? EstadoQ { get; set; }
    private string CompartirQuery => $"ubic={_ubicacionSel}&estado={Uri.EscapeDataString(_estado)}";

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
            _perfil = (await AuthState).User.FindFirst("perfil")?.Value ?? "";

        try { _ubicaciones = await Api.ListarUbicacionesAsync(); }
        catch { _ubicaciones = new(); }

        // Perfil → local. LURO=2, PERALTA=3 (fijan su ubicación). ADMIN puede elegir.
        var esLuro = string.Equals(_perfil, "LURO", StringComparison.OrdinalIgnoreCase);
        var esPeralta = string.Equals(_perfil, "PERALTA", StringComparison.OrdinalIgnoreCase);
        var esAdmin = string.Equals(_perfil, "ADMIN", StringComparison.OrdinalIgnoreCase);
        var esLogistica = string.Equals(_perfil, "LOGISTICA", StringComparison.OrdinalIgnoreCase);
        _puedeABM = esLuro || esPeralta || esAdmin;
        _esDeposito = esLogistica || esAdmin;   // depósito imprime el armado

        if (esLuro) { _ubicacionSel = 2; _ubicacionFija = true; _idLocalPedir = 2; }
        else if (esPeralta) { _ubicacionSel = 3; _ubicacionFija = true; _idLocalPedir = 3; }
        // ADMIN: arranca en TODOS; _idLocalPedir se setea si elige un local concreto.

        // Filtros del link (la ubicación se respeta solo si el perfil no la fija).
        if (!_ubicacionFija && UbicQ.HasValue) _ubicacionSel = UbicQ.Value;
        if (EstadoQ != null) _estado = EstadoQ;

        await Cargar();
    }

    private async Task Cargar()
    {
        _cargando = true;
        _error = null;
        // ADMIN: si el filtro es un local concreto (2/3), ese es con el que puede pedir.
        if (!_ubicacionFija)
            _idLocalPedir = (_ubicacionSel == 2 || _ubicacionSel == 3) ? _ubicacionSel : 0;
        try
        {
            int? ubic = _ubicacionSel == 0 ? null : _ubicacionSel;
            _pedidos = await Api.ListarPedidosAsync(ubic, _estado);
        }
        catch (Exception ex)
        {
            _pedidos = new();
            _error = "No se pudieron cargar los pedidos. Verificá la conexión a la base de datos.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task NuevoPedido()
    {
        if (_idLocalPedir == 0)
        {
            Ui.Error("Elegí un local (LURO o PERALTA) en el filtro de Ubicación para crear el pedido.");
            return;
        }
        try
        {
            var val = await Api.ValidarFechaAsync(_idLocalPedir);
            if (val.Resultado == "BLOQUEADO")
            {
                Ui.Error($"{val.Titulo} — {val.Mensaje}");
                return;
            }
            if (val.Resultado == "AVISO")
            {
                // Igual que el "Entendido" de la app Android: informa y deja pasar.
                Ui.Toast($"{val.Titulo} — {val.Mensaje}");
            }
            // No se crea nada en la base todavía: se arma en el editor y se persiste recién al Guardar.
            Nav.NavigateTo($"/insumos/pedidos/0?local={_idLocalPedir}");
        }
        catch (Exception ex)
        {
            Ui.Error(ex.Message);
        }
    }

    private void Abrir(PedidoInsumoDto p) => Nav.NavigateTo($"/insumos/pedidos/{p.Id}");

    // Solo lectura si está enviado; o si es el local y ya quedó cerrado (EN ARMADO).
    // El depósito puede editar EN ARMADO, así que para él no es solo lectura hasta ENVIADO.
    private bool SoloLectura(PedidoInsumoDto p) => p.Enviado || (!_esDeposito && p.Cerrado);

    // Depósito: imprime la hoja de ruta de los pendientes del filtro y los marca EN ARMADO.
    private async Task ImprimirArmado()
    {
        var ok = await Ui.ConfirmAsync(
            "Se va a imprimir el armado de los pedidos pendientes del filtro y quedarán EN ARMADO (cerrados para el local). ¿Continuar?", "Imprimir armado");
        if (!ok) return;
        try
        {
            int? ubic = _ubicacionSel == 0 ? null : _ubicacionSel;
            _armado = await Api.ImprimirArmadoAsync(ubic);
            if (_armado.Pedidos.Count == 0)
            {
                _armado = null;
                Ui.Toast("No hay pedidos pendientes para imprimir en este filtro.");
                return;
            }
            StateHasChanged();
            await Task.Delay(120);                 // dejar que se renderice la hoja solo-print
            try { await JS.InvokeVoidAsync("print"); } catch { }
            await Cargar();                         // refrescar: ahora quedan EN ARMADO
        }
        catch (Exception ex) { Ui.Error(ex.Message); Console.Error.WriteLine(ex); }
    }

    private bool _generando;

    // Depósito: genera el remito de insumos de cada local (Motivo 13) en Dragonfish y marca ENVIADO.
    // Solo crea el remito; la app del local lo imprime, despacha y acepta.
    private async Task GenerarRemitos()
    {
        var ok = await Ui.ConfirmAsync(
            "Se van a generar los remitos de insumos (uno por local) en Dragonfish con lo que quedó EN ARMADO. Los pedidos quedarán ENVIADOS. ¿Continuar?",
            "Generar remitos");
        if (!ok) return;
        _generando = true;
        try
        {
            int? ubic = _ubicacionSel == 0 ? null : _ubicacionSel;
            var res = await Api.GenerarRemitosAsync(ubic);

            if (res.Total == 0)
            {
                if (res.SinProcesar > 0)
                    Ui.Error($"Hay {res.SinProcesar} pedido(s) EN ARMADO sin guardar por depósito. Abrilos, acomodá según stock y guardá antes de remitir.");
                else
                    Ui.Toast("No hay pedidos EN ARMADO para remitir en este filtro.");
                return;
            }

            var okos = res.Locales.Where(l => l.Ok).Select(l => $"{l.Local} ({l.Comprobante})").ToList();
            var fallos = res.Locales.Where(l => !l.Ok).Select(l => $"{l.Local}: {l.Error}").ToList();
            if (okos.Count > 0) Ui.Exito($"Remitos generados: {string.Join(" · ", okos)}");
            if (fallos.Count > 0) Ui.Error($"Fallaron: {string.Join(" · ", fallos)}");
            if (res.SinProcesar > 0) Ui.Toast($"Quedaron {res.SinProcesar} pedido(s) EN ARMADO sin guardar por depósito (no se remitieron).");
            await Cargar();
        }
        catch (Exception ex) { Ui.Error(ex.Message); Console.Error.WriteLine(ex); }
        finally { _generando = false; }
    }

    // Genera el remito de un pedido puntual (a su local).
    private async Task GenerarRemitoPedido(PedidoInsumoDto p)
    {
        if (!await Ui.ConfirmAsync($"¿Generar el remito del pedido N° {p.NroPedido} ({p.Ubicacion})? Queda ENVIADO.", "Generar remito")) return;
        _generando = true;
        try
        {
            var r = await Api.GenerarRemitoPedidoAsync(p.Id);
            if (r.Ok) Ui.Exito($"Remito generado ({r.Comprobante}).");
            else Ui.Error(string.IsNullOrWhiteSpace(r.Error) ? "No se pudo generar el remito." : r.Error);
            await Cargar();
        }
        catch (Exception ex) { Ui.Error(ex.Message); Console.Error.WriteLine(ex); }
        finally { _generando = false; }
    }

    private async Task Eliminar(PedidoInsumoDto p)
    {
        // El local puede eliminar mientras DEPÓSITO no lo haya tomado (impreso/enviado).
        var ok = await Ui.ConfirmAsync($"¿Eliminar el pedido N° {p.NroPedido}?", "Eliminar pedido", "Eliminar", "Cancelar", peligro: true);
        if (!ok) return;
        try
        {
            var borrado = await Api.EliminarPedidoAsync(p.Id);
            if (!borrado)
                Ui.Error("El pedido ya fue tomado por Depósito (en armado/enviado): cerrado para el local.");
            await Cargar();
        }
        catch (Exception ex) { Console.Error.WriteLine(ex); }
    }
}
