@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject MarketWeb.Client.Services.UsoApi Uso

<div class="market-shell @(_menuAbierto ? "menu-abierto" : null)">
    <NavMenu />
    <div class="market-backdrop" @onclick="CerrarMenu"></div>
    <main class="market-content">
        <div class="market-topbar">
            <button class="market-burger" @onclick="ToggleMenu" title="Menú" aria-label="Menú">
                <i class="fa-solid fa-bars"></i>
            </button>
            <span class="market-topbar-brand">MARKET <b>WEB</b></span>
        </div>
        @Body
    </main>
</div>

<UiHost />

@code {
    // Drawer mobile: en celular el menú es un panel que entra desde el costado.
    // En desktop el sidebar está siempre visible (este estado no aplica).
    private bool _menuAbierto;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        RegistrarUso();   // página inicial
    }

    private void ToggleMenu() => _menuAbierto = !_menuAbierto;
    private void CerrarMenu() => _menuAbierto = false;

    // Al navegar (tocar un link del menú en mobile) se cierra solo + se registra el uso.
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_menuAbierto) { _menuAbierto = false; StateHasChanged(); }
        RegistrarUso();
    }

    // Cuenta la visita a una pantalla conocida (best-effort, no bloquea la navegación).
    private void RegistrarUso()
    {
        var acceso = MarketWeb.Client.Util.Accesos.Normalizar("/" + Nav.ToBaseRelativePath(Nav.Uri));
        if (acceso is not null) _ = Uso.RegistrarAsync(acceso.Ruta);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
