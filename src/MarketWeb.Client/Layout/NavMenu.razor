@implements IDisposable
@inject NavigationManager Nav

<div class="market-sidebar">
    <div class="market-brand">
        <NavLink href="" Match="NavLinkMatch.All">
            <span class="txt">
                <span class="name">MARKET</span>
                <span class="sub">WEB</span>
            </span>
        </NavLink>
    </div>

    <nav class="market-nav">
        @foreach (var modulo in Modulos.Where(VeModulo))
        {
            var abierto = _abierto == modulo.Titulo;
            <div class="market-module @(abierto ? "open" : "")">
                <button type="button" class="market-module-header" @onclick="() => Toggle(modulo.Titulo)">
                    <i class="@modulo.Icono ico"></i>
                    <span>@modulo.Titulo</span>
                    <i class="fa-solid fa-chevron-down market-caret"></i>
                </button>
                <div class="market-submenu">
                    @foreach (var item in modulo.Items)
                    {
                        @if (item.Sub is null)
                        {
                            <NavLink class="market-link" href="@item.Href">
                                <i class="@item.Icono ico"></i>
                                <span>@item.Etiqueta</span>
                                @if (!item.Implementado)
                                {
                                    <span class="market-wip" title="Pendiente de migrar"></span>
                                }
                            </NavLink>
                        }
                        else
                        {
                            var subKey = modulo.Titulo + "/" + item.Etiqueta;
                            <div class="market-subgroup @(_subsAbiertos.Contains(subKey) ? "open" : "")">
                                <div class="market-subgroup-header" role="button" tabindex="0" @onclick="() => ClickSubgrupo(subKey, item.Href)">
                                    <i class="@item.Icono ico"></i>
                                    <span>@item.Etiqueta</span>
                                    @if (!item.Implementado) { <span class="market-wip" title="Pendiente de migrar"></span> }
                                    <i class="fa-solid fa-chevron-down market-caret-sub" @onclick:stopPropagation="true" @onclick="() => ToggleSub(subKey)"></i>
                                </div>
                                <div class="market-subsubmenu">
                                    @foreach (var sub in item.Sub)
                                    {
                                        <NavLink class="market-link" href="@sub.Href">
                                            <i class="@sub.Icono ico"></i>
                                            <span>@sub.Etiqueta</span>
                                            @if (!sub.Implementado)
                                            {
                                                <span class="market-wip" title="Pendiente de migrar"></span>
                                            }
                                        </NavLink>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </nav>

    <div class="market-userbox">
        <AuthorizeView>
            <Authorized>
                <div class="userbox-row">
                    <div class="avatar">@Iniciales(context.User.Identity?.Name)</div>
                    <div class="info">
                        <span class="n">@context.User.Identity?.Name</span>
                        <span class="p">@Perfil(context.User)</span>
                    </div>
                    <button class="theme-toggle" title="@(_tema == "dark" ? "Modo claro" : "Modo oscuro")" @onclick="ToggleTema">
                        <i class="@(_tema == "dark" ? "fa-solid fa-sun" : "fa-solid fa-moon")"></i>
                    </button>
                    <button class="logout" title="Salir" @onclick="Logout"><i class="fa-solid fa-right-from-bracket"></i></button>
                </div>
                <EstaPcSelector />
            </Authorized>
            <NotAuthorized>
                <button class="btn-google" @onclick="Login">
                    <i class="fa-brands fa-google"></i> Entrar con Google
                </button>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<style>
    .market-subgroup-header {
        display: flex; align-items: center; gap: .6rem; width: 100%;
        background: none; border: 0; cursor: pointer; color: inherit; font: inherit; text-align: left;
        padding: .55rem .9rem; border-radius: 6px;
    }
    .market-subgroup-header:hover { background: rgba(128,128,128,.16); }
    .market-subgroup-header .ico { width: 1.15rem; text-align: center; opacity: .85; }
    .market-caret-sub { margin-left: auto; font-size: .62rem; opacity: .55; transition: transform .15s ease; }
    .market-subgroup.open > .market-subgroup-header .market-caret-sub { transform: rotate(180deg); }
    .market-subsubmenu { display: none; }
    .market-subgroup.open > .market-subsubmenu { display: block; }
    .market-subsubmenu .market-link { padding-left: 2.4rem; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private string? _abierto;
    private string _perfil = "";
    private string _tema = "light";

    private readonly HashSet<string> _subsAbiertos = new();

    private void Toggle(string titulo)
        => _abierto = _abierto == titulo ? null : titulo;

    private void ToggleSub(string key)
    {
        if (!_subsAbiertos.Remove(key)) _subsAbiertos.Add(key);
    }

    // Click en el encabezado de un subgrupo: si tiene ruta propia navega y lo despliega; si no, sólo despliega.
    private void ClickSubgrupo(string key, string? href)
    {
        if (!string.IsNullOrEmpty(href)) { _subsAbiertos.Add(key); Nav.NavigateTo(href); }
        else ToggleSub(key);
    }

    // Hojas (links navegables) de un módulo: las del subgrupo + el propio header si tiene ruta.
    private static IEnumerable<Item> Hojas(Modulo m) => m.Items.SelectMany(i =>
        i.Sub is null ? new[] { i }
        : (string.IsNullOrEmpty(i.Href) ? i.Sub : i.Sub.Prepend(i)));

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        if (AuthState is not null)
        {
            var state = await AuthState;
            _perfil = state.User.FindFirst("perfil")?.Value ?? "";
        }
        AbrirModuloDeRutaActual();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // El tema ya lo aplicó el script del index; acá solo reflejamos el ícono.
            try { _tema = await JS.InvokeAsync<string>("mkTema.get"); StateHasChanged(); } catch { }
        }
    }

    private async Task ToggleTema()
    {
        try { _tema = await JS.InvokeAsync<string>("mkTema.toggle"); } catch { }
    }

    // Módulos visibles por perfil (espejo de frmPrincipal). ADMIN ve todo; perfil desconocido, nada.
    private static readonly Dictionary<string, string[]> ModulosPorPerfil = new(StringComparer.OrdinalIgnoreCase)
    {
        ["LURO"] = new[] { "Locales" },
        ["PERALTA"] = new[] { "Locales" },
        ["LOGISTICA"] = new[] { "Configuración", "Logística" },
        ["DISEÑO"] = new[] { "Producción", "Informes" },
        ["DISENO"] = new[] { "Producción", "Informes" },
        ["ADMINISTRACION"] = new[] { "Administración", "Producción" },
    };

    private bool VeModulo(Modulo m)
    {
        if (string.Equals(_perfil, "ADMIN", StringComparison.OrdinalIgnoreCase)) return true;
        return ModulosPorPerfil.TryGetValue(_perfil, out var mods) && mods.Contains(m.Titulo);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        AbrirModuloDeRutaActual();
        StateHasChanged();
    }

    // Deja abierto el módulo cuya ruta coincide con la URL actual.
    private void AbrirModuloDeRutaActual()
    {
        var ruta = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        bool Coincide(Item i) => !string.IsNullOrEmpty(i.Href) && ruta.StartsWith(i.Href, StringComparison.OrdinalIgnoreCase);
        // Pantallas compartidas (una misma ruta en varios módulos, ej. Mapa en Logística y Producción):
        // si el módulo ya abierto también contiene la ruta, NO saltar a otro; se queda donde está el usuario.
        var actual = Modulos.FirstOrDefault(m => m.Titulo == _abierto);
        var modulo = (actual is not null && Hojas(actual).Any(Coincide))
            ? actual
            : Modulos.FirstOrDefault(m => Hojas(m).Any(Coincide));
        if (modulo is null) return;
        _abierto = modulo.Titulo;
        // Abrir también el subgrupo que contenga la ruta actual (por una hoja o por la ruta del propio header).
        foreach (var item in modulo.Items.Where(i => i.Sub is not null))
            if (Coincide(item) || item.Sub!.Any(Coincide))
                _subsAbiertos.Add(modulo.Titulo + "/" + item.Etiqueta);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    // Login/Logout: navegación de página completa (OAuth necesita redirección real).
    private void Login() => Nav.NavigateTo("api/auth/login", forceLoad: true);
    private void Logout() => Nav.NavigateTo("api/auth/logout", forceLoad: true);

    private static string Iniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "?";
        var partes = nombre.Split(new[] { ' ', '.', '@' }, StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length == 0) return "?";
        var ini = partes[0][..1];
        if (partes.Length > 1) ini += partes[1][..1];
        return ini.ToUpperInvariant();
    }

    private static string Perfil(System.Security.Claims.ClaimsPrincipal user)
        => user.FindFirst("perfil")?.Value ?? "Sin perfil";

    private sealed record Item(string Etiqueta, string Icono, string Href, bool Implementado = false, Item[]? Sub = null);
    private sealed record Modulo(string Titulo, string Icono, Item[] Items);

